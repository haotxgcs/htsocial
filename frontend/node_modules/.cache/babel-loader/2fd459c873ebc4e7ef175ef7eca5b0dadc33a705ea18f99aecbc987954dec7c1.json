{"ast":null,"code":"import MainHeader from './components/MainHeader.vue';\nexport default {\n  components: {\n    MainHeader\n  },\n  computed: {\n    showHeader() {\n      // Lấy đường dẫn hiện tại\n      const path = this.$route.path;\n      // Ẩn header ở các trang login, register, welcome\n      return !['/login', '/register', '/welcome'].includes(path);\n    }\n  }\n};","map":{"version":3,"names":["MainHeader","components","computed","showHeader","path","$route","includes"],"sources":["C:\\Users\\Yoga260\\Downloads\\Project\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <!-- Chỉ hiển thị Header nếu không phải là login/register/welcome -->\n    <MainHeader v-if=\"showHeader\" />\n    <router-view />\n  </div>\n</template>\n\n<script>\nimport MainHeader from './components/MainHeader.vue'\n\nexport default {\n  components: {\n    MainHeader\n  },\n  computed: {\n    showHeader() {\n      // Lấy đường dẫn hiện tại\n      const path = this.$route.path\n      // Ẩn header ở các trang login, register, welcome\n      return !['/login', '/register', '/welcome'].includes(path)\n    }\n  }\n}\n</script>\n\n\n\n<style>\nbody {\n  font-family: 'Segoe UI', sans-serif;\n  margin: 0;\n  background-color: #f4f4f4;\n}\n</style>\n"],"mappings":"AASA,OAAOA,UAAS,MAAO,6BAA4B;AAEnD,eAAe;EACbC,UAAU,EAAE;IACVD;EACF,CAAC;EACDE,QAAQ,EAAE;IACRC,UAAUA,CAAA,EAAG;MACX;MACA,MAAMC,IAAG,GAAI,IAAI,CAACC,MAAM,CAACD,IAAG;MAC5B;MACA,OAAO,CAAC,CAAC,QAAQ,EAAE,WAAW,EAAE,UAAU,CAAC,CAACE,QAAQ,CAACF,IAAI;IAC3D;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}