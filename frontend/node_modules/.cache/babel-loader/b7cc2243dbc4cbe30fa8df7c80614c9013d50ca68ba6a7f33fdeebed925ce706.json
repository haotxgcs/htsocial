{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: \"VerifyPage\",\n  data() {\n    return {\n      code: \"\",\n      email: \"\",\n      error: \"\",\n      success: \"\",\n      resendDisabled: true,\n      countdown: 60\n    };\n  },\n  mounted() {\n    this.email = localStorage.getItem(\"pendingEmail\") || \"\";\n    this.startCountdown();\n  },\n  methods: {\n    async verify() {\n      this.error = \"\";\n      try {\n        const res = await fetch(\"http://localhost:3000/users/verify\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\"\n          },\n          body: JSON.stringify({\n            email: this.email,\n            code: this.code\n          })\n        });\n        const data = await res.json();\n        if (!res.ok) throw new Error(data.msg || \"Verification failed\");\n        this.success = \"Account verified!\";\n        localStorage.removeItem(\"pendingEmail\");\n        setTimeout(() => this.$router.push(\"/home\"), 1500);\n      } catch (err) {\n        this.error = err.message;\n      }\n    },\n    async resendCode() {\n      try {\n        const res = await fetch(\"http://localhost:3000/users/resend-code\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\"\n          },\n          body: JSON.stringify({\n            email: this.email\n          })\n        });\n        const data = await res.json();\n        if (!res.ok) throw new Error(data.msg || \"Resend failed\");\n        this.success = \"New code sent!\";\n        this.startCountdown();\n      } catch (err) {\n        this.error = err.message;\n      }\n    },\n    startCountdown() {\n      this.resendDisabled = true;\n      this.countdown = 60;\n      const timer = setInterval(() => {\n        this.countdown--;\n        if (this.countdown <= 0) {\n          this.resendDisabled = false;\n          clearInterval(timer);\n        }\n      }, 1000);\n    }\n  }\n};","map":{"version":3,"names":["name","data","code","email","error","success","resendDisabled","countdown","mounted","localStorage","getItem","startCountdown","methods","verify","res","fetch","method","headers","body","JSON","stringify","json","ok","Error","msg","removeItem","setTimeout","$router","push","err","message","resendCode","timer","setInterval","clearInterval"],"sources":["C:\\Users\\Yoga260\\Downloads\\COMP1842 - Web Programming 2\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\VerifyPage.vue"],"sourcesContent":["<template>\r\n  <div class=\"form-container\">\r\n    <h2>Verify Your Account</h2>\r\n    <p class=\"info\">Verification code has been sent to: <strong>{{ email }}</strong></p>\r\n\r\n    <form @submit.prevent=\"verify\">\r\n      <input v-model=\"code\" placeholder=\"Enter 4-digit code\" maxlength=\"4\" required />\r\n      <button type=\"submit\">Verify</button>\r\n    </form>\r\n\r\n    <button @click=\"resendCode\" :disabled=\"resendDisabled\">\r\n      {{ resendDisabled ? `Resend in ${countdown}s` : \"Resend Code\" }}\r\n    </button>\r\n\r\n    <p v-if=\"error\" class=\"error\">{{ error }}</p>\r\n    <p v-if=\"success\" class=\"success\">{{ success }}</p>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"VerifyPage\",\r\n  data() {\r\n    return {\r\n      code: \"\",\r\n      email: \"\",\r\n      error: \"\",\r\n      success: \"\",\r\n      resendDisabled: true,\r\n      countdown: 60\r\n    };\r\n  },\r\n  mounted() {\r\n    this.email = localStorage.getItem(\"pendingEmail\") || \"\";\r\n    this.startCountdown();\r\n  },\r\n  methods: {\r\n    async verify() {\r\n      this.error = \"\";\r\n      try {\r\n        const res = await fetch(\"http://localhost:3000/users/verify\", {\r\n          method: \"POST\",\r\n          headers: { \"Content-Type\": \"application/json\" },\r\n          body: JSON.stringify({ email: this.email, code: this.code })\r\n        });\r\n        const data = await res.json();\r\n        if (!res.ok) throw new Error(data.msg || \"Verification failed\");\r\n\r\n        this.success = \"Account verified!\";\r\n        localStorage.removeItem(\"pendingEmail\");\r\n        setTimeout(() => this.$router.push(\"/home\"), 1500);\r\n      } catch (err) {\r\n        this.error = err.message;\r\n      }\r\n    },\r\n    async resendCode() {\r\n      try {\r\n        const res = await fetch(\"http://localhost:3000/users/resend-code\", {\r\n          method: \"POST\",\r\n          headers: { \"Content-Type\": \"application/json\" },\r\n          body: JSON.stringify({ email: this.email })\r\n        });\r\n        const data = await res.json();\r\n        if (!res.ok) throw new Error(data.msg || \"Resend failed\");\r\n\r\n        this.success = \"New code sent!\";\r\n        this.startCountdown();\r\n      } catch (err) {\r\n        this.error = err.message;\r\n      }\r\n    },\r\n    startCountdown() {\r\n      this.resendDisabled = true;\r\n      this.countdown = 60;\r\n      const timer = setInterval(() => {\r\n        this.countdown--;\r\n        if (this.countdown <= 0) {\r\n          this.resendDisabled = false;\r\n          clearInterval(timer);\r\n        }\r\n      }, 1000);\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.form-container {\r\n  max-width: 400px;\r\n  margin: 80px auto;\r\n  background: white;\r\n  padding: 30px;\r\n  border-radius: 8px;\r\n  text-align: center;\r\n}\r\ninput {\r\n  width: 100%;\r\n  padding: 10px;\r\n  margin: 12px 0;\r\n}\r\nbutton {\r\n  width: 100%;\r\n  padding: 10px;\r\n  margin-top: 10px;\r\n  background-color: #42b983;\r\n  color: white;\r\n  border: none;\r\n  border-radius: 4px;\r\n}\r\nbutton[disabled] {\r\n  background-color: #aaa;\r\n}\r\n.error {\r\n  color: red;\r\n  margin-top: 10px;\r\n}\r\n.success {\r\n  color: green;\r\n  margin-top: 10px;\r\n}\r\n.info {\r\n  color: #444;\r\n}\r\n</style>\r\n"],"mappings":";AAoBA,eAAe;EACbA,IAAI,