\n  overflow: hidden;\r\n  cursor: pointer;\r\n  transition: transform 0.2s ease;\r\n}\r\n\r\n.product-item:hover {\r\n  transform: scale(1.02);\r\n}\r\n\r\n.product-image {\r\n  width: 100%;\r\n  height: 260px;\r\n  overflow: hidden;\r\n}\r\n\r\n.product-image img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.product-info {\r\n  padding: 12px;\r\n}\r\n\r\n.product-price {\r\n  font-size: 16px;\r\n  font-weight: 600;\r\n  color: #1c1e21;\r\n  margin-bottom: 4px;\r\n}\r\n\r\n.product-title {\r\n  font-size: 14px;\r\n  color: #1c1e21;\r\n  line-height: 1.3;\r\n  margin-bottom: 4px;\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 2;\r\n  -webkit-box-orient: vertical;\r\n  overflow: hidden;\r\n}\r\n\r\n.product-location {\r\n  font-size: 12px;\r\n  color: #65676b;\r\n}\r\n\r\n/* Responsive */\r\n@media (max-width: 1200px) {\r\n  .products-grid {\r\n    grid-template-columns: repeat(3, 1fr);\r\n  }\r\n}\r\n\r\n@media (max-width: 900px) {\r\n  .products-grid {\r\n    grid-template-columns: repeat(2, 1fr);\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .sidebar {\r\n    transform: translateX(-100%);\r\n  }\r\n  \r\n  .main-content {\r\n    margin-left: 0;\r\n  }\r\n  \r\n  .header-center {\r\n    display: none;\r\n  }\r\n  \r\n  .search-box input {\r\n    width: 180px;\r\n  }\r\n}\r\n</style>"],"mappings":"AA2JA,eAAe;EACbA,IAAI,EAAE,iBAAiB;EACvBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAE,EAAE;MACfC,QAAQ,EAAE,CACR;QACEC,EAAE,EAAE,CAAC;QACLC,KAAK,EAAE,YAAY;QACnBC,KAAK,EAAE,oCAAoC;QAC3CC,QAAQ,EAAE,SAAS;QACnBC,KAAK,EAAE;MACT,CAAC,EACD;QACEJ,EAAE,EAAE,CAAC;QACLC,KAAK,EAAE,YAAY;QACnBC,KAAK,EAAE,aAAa;QACpBC,QAAQ,EAAE,6BAA6B;QACvCC,KAAK,EAAE;MACT,CAAC,EACD;QACEJ,EAAE,EAAE,CAAC;QACLC,KAAK,EAAE,YAAY;QACnBC,KAAK,EAAE,4BAA4B;QACnCC,QAAQ,EAAE,SAAS;QACnBC,KAAK,EAAE;MACT,CAAC,EACD;QACEJ,EAAE,EAAE,CAAC;QACLC,KAAK,EAAE,YAAY;QACnBC,KAAK,EAAE,aAAa;QACpBC,QAAQ,EAAE,SAAS;QACnBC,KAAK,EAAE;MACT,CAAC,EACD;QACEJ,EAAE,EAAE,CAAC;QACLC,KAAK,EAAE,YAAY;QACnBC,KAAK