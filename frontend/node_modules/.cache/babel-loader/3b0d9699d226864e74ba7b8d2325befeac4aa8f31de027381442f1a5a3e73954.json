{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/es.set.difference.v2.js\";\nimport \"core-js/modules/es.set.intersection.v2.js\";\nimport \"core-js/modules/es.set.is-disjoint-from.v2.js\";\nimport \"core-js/modules/es.set.is-subset-of.v2.js\";\nimport \"core-js/modules/es.set.is-superset-of.v2.js\";\nimport \"core-js/modules/es.set.symmetric-difference.v2.js\";\nimport \"core-js/modules/es.set.union.v2.js\";\nimport axios from \"axios\";\nimport \"../styles/ProductList.css\"; // Import CSS file\n\nexport default {\n  data() {\n    return {\n      products: [],\n      // List of products\n      selectedCategory: \"All\" // Default selected category\n    };\n  },\n  computed: {\n    // Get unique categories from products\n    uniqueCategories() {\n      const categories = new Set(this.products.map(product => product.category));\n      return Array.from(categories);\n    },\n    // Filter products based on selected category\n    filteredProducts() {\n      if (this.selectedCategory === \"All\") {\n        return this.products;\n      }\n      return this.products.filter(product => product.category === this.selectedCategory);\n    }\n  },\n  methods: {\n    // Fetch products from the backend\n    async fetchProducts() {\n      try {\n        const response = await axios.get(\"http://localhost:3000/product\");\n        this.products = response.data.map(product => ({\n          ...product,\n          editing: false,\n          newPrice: product.price,\n          newQuantity: product.quantity,\n          priceError: \"\",\n          quantityError: \"\"\n        }));\n      } catch (error) {\n        console.error(\"Error fetching products:\", error);\n      }\n    },\n    // Toggle edit mode for a product\n    toggleEdit(product) {\n      product.editing = !product.editing;\n      if (!product.editing) {\n        product.newPrice = product.price;\n        product.newQuantity = product.quantity;\n        product.priceError = \"\";\n        product.quantityError = \"\";\n      }\n    },\n    // Validate price input\n    validatePrice(product) {\n      const price = parseFloat(product.newPrice);\n      if (isNaN(price) || price <= 0) {\n        product.priceError = \"Price must be greater than 0!\";\n      } else {\n        product.priceError = \"\";\n      }\n    },\n    // Validate quantity input\n    validateQuantity(product) {\n      if (product.newQuantity < 1) {\n        product.quantityError = \"Quantity must be at least 1!\";\n      } else {\n        product.quantityError = \"\";\n      }\n    },\n    // Check if all fields are valid before saving\n    isValid(product) {\n      return parseFloat(product.newPrice) > 0 && product.newQuantity >= 1 && !product.priceError && !product.quantityError;\n    },\n    // Save edited product details\n    async saveEdit(product) {\n      if (!this.isValid(product)) return;\n      try {\n        await axios.put(`http://localhost:3000/product/${product._id}`, {\n          product_name: product.product_name,\n          description: product.description,\n          price: parseFloat(product.newPrice),\n          // ✅ Ensure the price is saved as a floating number\n          category: product.category,\n          quantity: product.newQuantity\n        });\n\n        // Update product data after saving\n        product.price = parseFloat(product.newPrice);\n        product.quantity = product.newQuantity;\n        product.editing = false;\n      } catch (error) {\n        console.error(\"Error updating product:\", error);\n      }\n    },\n    // Delete a product\n    async deleteProduct(id) {\n      try {\n        await axios.delete(`http://localhost:3000/product/${id}`);\n        this.products = this.products.filter(product => product._id !== id);\n      } catch (error) {\n        console.error(\"Error deleting product:\", error);\n      }\n    }\n  },\n  // Fetch products when the component is mounted\n  mounted() {\n    this.fetchProducts();\n  }\n};","map":{"version":3,"names":["axios","data","products","selectedCategory","computed","uniqueCategories","categories","Set","map","product","category","Array","from","filteredProducts","filter","methods","fetchProducts","response","get","editing","newPrice","price","newQuantity","quantity","priceError","quantityError","error","console","toggleEdit","validatePrice","parseFloat","isNaN","validateQuantity","isValid","saveEdit","put","_id","product_name","description","deleteProduct","id","delete","mounted"],"sources":["C:\\TRẦN XUÂN HÀO\\Semester 6\\COMP1842 - Web Programming 2\\coursework\\front-end\\src\\components\\ProductList.vue"],"sourcesContent":["<template>\r\n  <div class=\"product-list\">\r\n    <h2>Product List</h2>\r\n\r\n    <!-- Dropdown for selecting product category -->\r\n    <div class=\"filter-container\">\r\n      <label for=\"categoryFilter\">Filter by Category:</label>\r\n      <select v-model=\"selectedCategory\">\r\n        <option value=\"All\">All Categories</option>\r\n        <option v-for=\"category in uniqueCategories\" :key=\"category\" :value=\"category\">\r\n          {{ category }}\r\n        </option>\r\n      </select>\r\n    </div>\r\n\r\n    <!-- Display products if available -->\r\n    <ul v-if=\"filteredProducts.length > 0\">\r\n      <li v-for=\"product in filteredProducts\" :key=\"product._id\" class=\"product-card\">\r\n        \r\n        <!-- Display product details -->\r\n        <div v-if=\"!product.editing\">\r\n          <h3>{{ product.product_name }}</h3>\r\n          <p><strong>Description:</strong> {{ product.description }}</p>\r\n          <p><strong>Price:</strong> <span class=\"badge\">${{ product.price }}</span></p>\r\n          <p><strong>Category:</strong> <span class=\"badge category\">{{ product.category }}</span></p>\r\n          <p><strong>Quantity:</strong> {{ product.quantity }}</p>\r\n        </div>\r\n\r\n        <!-- Edit form for updating product details -->\r\n        <div v-else>\r\n          <input v-model=\"product.product_name\" placeholder=\"Edit name\" />\r\n          <input v-model=\"product.description\" placeholder=\"Edit description\" />\r\n\r\n          <!-- Price input with validation -->\r\n          <input \r\n            v-model=\"product.newPrice\" \r\n            type=\"number\" \r\n            min=\"0.01\" \r\n            step=\"0.01\" \r\n            placeholder=\"Edit price\"\r\n            @input=\"validatePrice(product)\"\r\n          />\r\n          <p v-if=\"product.priceError\" class=\"error-message\">{{ product.priceError }}</p>\r\n\r\n          <input v-model=\"product.category\" placeholder=\"Edit category\" />\r\n\r\n          <!-- Quantity input with validation -->\r\n          <input \r\n            v-model=\"product.newQuantity\" \r\n            type=\"number\" \r\n            min=\"1\" \r\n            placeholder=\"Edit quantity\"\r\n            @input=\"validateQuantity(product)\"\r\n          />\r\n          <p v-if=\"product.quantityError\" class=\"error-message\">{{ product.quantityError }}</p>\r\n\r\n          <!-- Save button (disabled if validation fails) -->\r\n          <button @click=\"saveEdit(product)\" :disabled=\"!isValid(product)\">Save</button>\r\n        </div>\r\n\r\n        <!-- Action buttons (Edit & Delete) -->\r\n        <div class=\"actions\">\r\n          <button @click=\"toggleEdit(product)\">\r\n            {{ product.editing ? \"Cancel\" : \"Edit\" }}\r\n          </button>\r\n          <button @click=\"deleteProduct(product._id)\" class=\"delete-btn\">Delete</button>\r\n        </div>\r\n      </li>\r\n    </ul>\r\n\r\n    <!-- Display message if no products are available -->\r\n    <p v-else class=\"empty-message\">No products available.</p>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"axios\";\r\nimport \"../styles/ProductList.css\"; // Import CSS file\r\n\r\nexport default {\r\n  data() {\r\n    return {\r\n      products: [], // List of products\r\n      selectedCategory: \"All\", // Default selected category\r\n    };\r\n  },\r\n  computed: {\r\n    // Get unique categories from products\r\n    uniqueCategories() {\r\n      const categories = new Set(this.products.map(product => product.category));\r\n      return Array.from(categories);\r\n    },\r\n    // Filter products based on selected category\r\n    filteredProducts() {\r\n      if (this.selectedCategory === \"All\") {\r\n        return this.products;\r\n      }\r\n      return this.products.filter(product => product.category === this.selectedCategory);\r\n    }\r\n  },\r\n  methods: {\r\n    // Fetch products from the backend\r\n    async fetchProducts() {\r\n      try {\r\n        const response = await axios.get(\"http://localhost:3000/product\");\r\n        this.products = response.data.map(product => ({\r\n          ...product, \r\n          editing: false,\r\n          newPrice: product.price,\r\n          newQuantity: product.quantity,\r\n          priceError: \"\",\r\n          quantityError: \"\"\r\n        }));\r\n      } catch (error) {\r\n        console.error(\"Error fetching products:\", error);\r\n      }\r\n    },\r\n    // Toggle edit mode for a product\r\n    toggleEdit(product) {\r\n      product.editing = !product.editing;\r\n      if (!product.editing) {\r\n        product.newPrice = product.price;\r\n        product.newQuantity = product.quantity;\r\n        product.priceError = \"\";\r\n        product.quantityError = \"\";\r\n      }\r\n    },\r\n    // Validate price input\r\n    validatePrice(product) {\r\n      const price = parseFloat(product.newPrice);\r\n      if (isNaN(price) || price <= 0) {\r\n        product.priceError = \"Price must be greater than 0!\";\r\n      } else {\r\n        product.priceError = \"\";\r\n      }\r\n    },\r\n    // Validate quantity input\r\n    validateQuantity(product) {\r\n      if (product.newQuantity < 1) {\r\n        product.quantityError = \"Quantity must be at least 1!\";\r\n      } else {\r\n        product.quantityError = \"\";\r\n      }\r\n    },\r\n    // Check if all fields are valid before saving\r\n    isValid(product) {\r\n      return (\r\n        parseFloat(product.newPrice) > 0 &&\r\n        product.newQuantity >= 1 &&\r\n        !product.priceError &&\r\n        !product.quantityError\r\n      );\r\n    },\r\n    // Save edited product details\r\n    async saveEdit(product) {\r\n      if (!this.isValid(product)) return;\r\n\r\n      try {\r\n        await axios.put(`http://localhost:3000/product/${product._id}`, {\r\n          product_name: product.product_name,\r\n          description: product.description,\r\n          price: parseFloat(product.newPrice), // ✅ Ensure the price is saved as a floating number\r\n          category: product.category,\r\n          quantity: product.newQuantity\r\n        });\r\n\r\n        // Update product data after saving\r\n        product.price = parseFloat(product.newPrice);\r\n        product.quantity = product.newQuantity;\r\n        product.editing = false;\r\n      } catch (error) {\r\n        console.error(\"Error updating product:\", error);\r\n      }\r\n    },\r\n    // Delete a product\r\n    async deleteProduct(id) {\r\n      try {\r\n        await axios.delete(`http://localhost:3000/product/${id}`);\r\n        this.products = this.products.filter(product => product._id !== id);\r\n      } catch (error) {\r\n        console.error(\"Error deleting product:\", error);\r\n      }\r\n    }\r\n  },\r\n  // Fetch products when the component is mounted\r\n  mounted() {\r\n    this.fetchProducts();\r\n  }\r\n};\r\n</script>\r\n\r\n<style>\r\n/* Main container for the product list */\r\n.product-list {\r\n  max-width: 800px; /* Set a maximum width */\r\n  margin: 20px auto; /* Center the container */\r\n  padding: 20px; /* Add padding */\r\n  background: #e6f7ff; /* Light background */\r\n  border-radius: 12px; /* Rounded corners */\r\n  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15); /* Subtle shadow effect */\r\n  text-align: center; /* Center align text */\r\n}\r\n\r\n/* Product list title */\r\nh2 {\r\n  color: #333; /* Dark text */\r\n  font-size: 24px; /* Set font size */\r\n  margin-bottom: 15px; /* Space below title */\r\n}\r\n\r\n/* Remove default list styling */\r\nul {\r\n  list-style: none;\r\n  padding: 0;\r\n}\r\n\r\n/* Each product is displayed in a separate white card */\r\n.product-card {\r\n  background: white; /* White background */\r\n  margin: 15px 0; /* Space between product cards */\r\n  padding: 20px; /* Padding inside cards */\r\n  border-radius: 12px; /* Rounded corners */\r\n  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); /* Soft shadow */\r\n  transition: transform 0.2s ease-in-out; /* Smooth scaling effect */\r\n  border: 2px solid #d1d1d1; /* Light border for separation */\r\n}\r\n\r\n/* Hover effect on product cards */\r\n.product-card:hover {\r\n  transform: scale(1.02); /* Slightly enlarge on hover */\r\n  box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15); /* Stronger shadow */\r\n}\r\n\r\n/* Product title */\r\n.product-card h3 {\r\n  margin: 0;\r\n  color: #007bff; /* Blue title */\r\n  font-size: 20px; /* Font size */\r\n}\r\n\r\n/* Product details */\r\n.product-card p {\r\n  margin: 5px 0;\r\n  color: #444; /* Dark text */\r\n  font-size: 16px;\r\n}\r\n\r\n/* Badge for price */\r\n.badge {\r\n  padding: 6px 12px;\r\n  border-radius: 5px;\r\n  background: #007bff; /* Blue background */\r\n  color: white; /* White text */\r\n  font-weight: bold;\r\n  display: inline-block;\r\n}\r\n\r\n/* Badge for category */\r\n.category {\r\n  background: #28a745; /* Green background */\r\n}\r\n\r\n/* Quantity display */\r\n.quantity {\r\n  font-weight: bold;\r\n  color: #222;\r\n}\r\n\r\n/* Action buttons container */\r\n.actions {\r\n  display: flex;\r\n  justify-content: center;\r\n  gap: 10px;\r\n  margin-top: 10px;\r\n}\r\n\r\n/* Button styling */\r\nbutton {\r\n  cursor: pointer;\r\n  border: none;\r\n  padding: 8px 12px;\r\n  border-radius: 6px;\r\n  font-size: 14px;\r\n  transition: 0.2s;\r\n}\r\n\r\nbutton:hover {\r\n  opacity: 0.8; /* Reduce opacity on hover */\r\n}\r\n\r\n/* Edit button styling */\r\nbutton.edit-btn {\r\n  background: #ffc107; /* Yellow background */\r\n  color: black;\r\n}\r\n\r\n/* Delete button styling */\r\nbutton.delete-btn {\r\n  background: #dc3545; /* Red background */\r\n  color: white;\r\n}\r\n\r\n/* Input fields in edit form */\r\ninput {\r\n  width: 100%;\r\n  padding: 8px;\r\n  margin: 5px 0;\r\n  border-radius: 6px;\r\n  border: 1px solid #ccc;\r\n  font-size: 14px;\r\n}\r\n\r\n/* Message displayed when no products are available */\r\n.empty-message {\r\n  text-align: center;\r\n  color: #ff0000;\r\n  font-weight: bold;\r\n  margin-top: 20px;\r\n}\r\n\r\n/* Category filter container */\r\n.filter-container {\r\n  margin-bottom: 15px;\r\n  text-align: center;\r\n}\r\n\r\n.filter-container label {\r\n  font-weight: bold;\r\n  margin-right: 8px;\r\n}\r\n\r\n/* Styling for category dropdown */\r\n.filter-container select {\r\n  padding: 8px;\r\n  border-radius: 6px;\r\n  border: 1px solid #ccc;\r\n  font-size: 14px;\r\n  transition: border-color 0.2s;\r\n}\r\n\r\n/* Highlight category dropdown on focus */\r\n.filter-container select:focus {\r\n  border-color: #007bff;\r\n  outline: none;\r\n}\r\n\r\n/* Ensure error messages always display in red */\r\n.error-message {\r\n  color: red !important; /* Ensure red text is not overridden */\r\n  font-size: 14px;\r\n  margin-top: 5px;\r\n}\r\n\r\n</style>"],"mappings":";;;;;;;;;;AA4EA,OAAOA,KAAI,MAAO,OAAO;AACzB,OAAO,2BAA2B,EAAE;;AAEpC,eAAe;EACbC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,EAAE;MAAE;MACdC,gBAAgB,EAAE,KAAK,CAAE;IAC3B,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACR;IACAC,gBAAgBA,CAAA,EAAG;MACjB,MAAMC,UAAS,GAAI,IAAIC,GAAG,CAAC,IAAI,CAACL,QAAQ,CAACM,GAAG,CAACC,OAAM,IAAKA,OAAO,CAACC,QAAQ,CAAC,CAAC;MAC1E,OAAOC,KAAK,CAACC,IAAI,CAACN,UAAU,CAAC;IAC/B,CAAC;IACD;IAC