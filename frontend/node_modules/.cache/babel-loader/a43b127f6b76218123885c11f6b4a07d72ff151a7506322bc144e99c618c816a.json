{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'LoginPage',\n  data() {\n    return {\n      username: '',\n      password: '',\n      error: ''\n    };\n  },\n  methods: {\n    async handleLogin() {\n      try {\n        const response = await axios.post(\"http://localhost:3000/api/auth/login\", {\n          username: this.username,\n          password: this.password\n        });\n\n        // ✅ Lưu user & token nếu cần\n        localStorage.setItem(\"user\", JSON.stringify(response.data.user));\n        localStorage.setItem(\"token\", response.data.token);\n\n        // ✅ Chuyển sang trang Home\n        this.$router.push(\"/home\");\n      } catch (error) {\n        this.error = error.response?.data?.msg || \"Login failed\";\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","username","password","error","methods","handleLogin","response","axios","post","localStorage","setItem","JSON","stringify","user","token","$router","push","msg"],"sources":["C:\\Users\\Yoga260\\Downloads\\COMP1842 - Web Programming 2\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\LoginPage.vue"],"sourcesContent":["<template>\r\n  <div class=\"form-container\">\r\n    <h2>Login</h2>\r\n    <form @submit.prevent=\"handleLogin\">\r\n      <input v-model=\"username\" placeholder=\"Username\" required />\r\n      <input v-model=\"password\" type=\"password\" placeholder=\"Password\" required />\r\n      <button type=\"submit\">Login</button>\r\n    </form>\r\n    <p v-if=\"error\">{{ error }}</p>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'LoginPage',\r\n  data() {\r\n    return {\r\n      username: '',\r\n      password: '',\r\n      error: ''\r\n    }\r\n  },\r\n  methods: {\r\n  async handleLogin() {\r\n    try {\r\n      const response = await axios.post(\"http://localhost:3000/api/auth/login\", {\r\n        username: this.username,\r\n        password: this.password,\r\n      });\r\n\r\n      // ✅ Lưu user & token nếu cần\r\n      localStorage.setItem(\"user\", JSON.stringify(response.data.user));\r\n      localStorage.setItem(\"token\", response.data.token);\r\n\r\n      // ✅ Chuyển sang trang Home\r\n      this.$router.push(\"/home\");\r\n    } catch (error) {\r\n      this.error = error.response?.data?.msg || \"Login failed\";\r\n    }\r\n  }\r\n}\r\n\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.form-container {\r\n  max-width: 400px;\r\n  margin: 100px auto;\r\n  background: white;\r\n  padding: 30px;\r\n  border-radius: 8px;\r\n}\r\ninput {\r\n  display: block;\r\n  width: 100%;\r\n  padding: 10px;\r\n  margin: 12px 0;\r\n}\r\nbutton {\r\n  padding: 10px;\r\n  width: 100%;\r\n  background-color: #42b983;\r\n}\r\n</style>\r\n"],"mappings":";AAaA,eAAe;EACbA,IAAI,EAAE,WAAW;EACjBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,EAAE;MACZC,QAAQ,EAAE,EAAE;MACZC,KAAK,EAAE;IACT;EACF,CAAC;EACDC,OAAO,EAAE;IACT,MAAMC,WAAWA,CAAA,EAAG;MAClB,IAAI;QACF,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAACC,IAAI,CAAC,sCAAsC,EAAE;UACxEP,QAAQ,EAAE,IAAI,CAACA,QAAQ;UACvBC,QAAQ,EAAE,IAAI,CAACA;QACjB,CAAC,CAAC;;QAEF;QACAO,YAAY,CAACC,OAAO,CAAC,MAAM,EAAEC,IAAI,CAACC,SAAS,CAACN,QAAQ,CAACN,IAAI,CAACa,IAAI,CAAC,CAAC;QAChEJ,YAAY,CAACC,OAAO,CAAC,OAAO,EAAEJ,QAAQ,CAACN,IAAI,CAACc,KAAK,CAAC;;QAElD;QACA,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,OAAO,CAAC;MAC5B,EAAE,OAAOb,KAAK,EAAE;QACd,IAAI,CAACA,KAAI,GAAIA,KAAK,CAACG,QAAQ,EAAEN,IAAI,EAAEiB,GAAE,IAAK,cAAc;MAC1D;IACF;EACF;AAEA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}