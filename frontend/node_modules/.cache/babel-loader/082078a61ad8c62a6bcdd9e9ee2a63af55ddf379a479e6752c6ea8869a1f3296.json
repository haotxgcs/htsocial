{"ast":null,"code":"export default {\n  props: [\"post\"],\n  data() {\n    return {\n      newComment: \"\",\n      comments: []\n    };\n  },\n  methods: {\n    close() {\n      this.$emit(\"close\");\n    },\n    formatTime(dateStr) {\n      return new Date(dateStr).toLocaleString();\n    },\n    getAvatar(path) {\n      return path ? `http://localhost:3000/${path}` : \"../assets/user.png\";\n    },\n    getMedia(path) {\n      return `http://localhost:3000/${path}`;\n    },\n    async loadComments() {\n      try {\n        const res = await this.$axios.get(`/comments/posts/${this.post._id}`);\n        this.comments = res.data;\n      } catch (err) {\n        console.error(\"Lỗi khi tải comments:\", err);\n      }\n    },\n    async sendComment() {\n      if (!this.newComment.trim()) return;\n      const savedUser = JSON.parse(localStorage.getItem(\"user\"));\n      if (!savedUser) return alert(\"Bạn chưa đăng nhập\");\n      try {\n        const res = await this.$axios.post(\"http://localhost:3000/comments\", {\n          post: this.post._id,\n          author: savedUser.username,\n          content: this.newComment\n        });\n        this.comments.unshift(res.data.comment); // thêm bình luận mới vào đầu danh sách\n        this.newComment = \"\";\n      } catch (err) {\n        console.error(\"Lỗi khi gửi bình luận:\", err);\n        alert(\"Không thể gửi bình luận\");\n      }\n    },\n    replyTo(name) {\n      this.newComment = `@${name} `;\n    }\n  },\n  mounted() {\n    this.loadComments();\n  }\n};","map":{"version":3,"names":["props","data","newComment","comments","methods","close","$emit","formatTime","dateStr","Date","toLocaleString","getAvatar","path","getMedia","loadComments","res","$axios","get","post","_id","err","console","error","sendComment","trim","savedUser","JSON","parse","localStorage","getItem","alert","author","username","content","unshift","comment","replyTo","name","mounted"],"sources":["C:\\Users\\Yoga260\\Downloads\\Project\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\PostDetailModal.vue"],"sourcesContent":["<template>\r\n  <div class=\"overlay\" @click.self=\"close\">\r\n    <div class=\"modal\">\r\n      <!-- Header -->\r\n      <div class=\"post-header\">\r\n        <img :src=\"getAvatar(post?.author?.avatar)\" />\r\n        <div>\r\n          <strong>{{ post?.author?.firstname }} {{ post?.author?.lastname }}</strong>\r\n          <p>{{ formatTime(post?.createdAt) }}</p>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Nội dung -->\r\n      <p class=\"post-content\">{{ post?.content }}</p>\r\n\r\n      <!-- Media -->\r\n      <div v-if=\"post?.media\">\r\n        <img v-if=\"post?.mediaType === 'image'\" :src=\"getMedia(post.media)\" />\r\n        <video v-else controls>\r\n          <source :src=\"getMedia(post.media)\" type=\"video/mp4\" />\r\n        </video>\r\n      </div>\r\n\r\n      <!-- Comment list -->\r\n      <div class=\"comments\">\r\n        <div v-for=\"(c, index) in comments\" :key=\"index\" class=\"comment\">\r\n          <p><strong>{{ c.author?.username }}:</strong> {{ c.content }}</p>\r\n          <small @click=\"replyTo(c.author?.username)\">↳ Trả lời</small>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Bình luận -->\r\n      <div class=\"comment-box\">\r\n        <input v-model=\"newComment\" placeholder=\"Viết bình luận...\" />\r\n        <button @click=\"sendComment\">Gửi</button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  props: [\"post\"],\r\n  data() {\r\n    return {\r\n      newComment: \"\",\r\n      comments: []\r\n    };\r\n  },\r\n  methods: {\r\n    close() {\r\n      this.$emit(\"close\");\r\n    },\r\n    formatTime(dateStr) {\r\n      return new Date(dateStr).toLocaleString();\r\n    },\r\n    getAvatar(path) {\r\n      return path ? `http://localhost:3000/${path}` : \"../assets/user.png\";\r\n    },\r\n    getMedia(path) {\r\n      return `http://localhost:3000/${path}`;\r\n    },\r\n    async loadComments() {\r\n      try {\r\n        const res = await this.$axios.get(`/comments/posts/${this.post._id}`);\r\n        this.comments = res.data;\r\n      } catch (err) {\r\n        console.error(\"Lỗi khi tải comments:\", err);\r\n      }\r\n    },\r\n    async sendComment() {\r\n  if (!this.newComment.trim()) return;\r\n\r\n  const savedUser = JSON.parse(localStorage.getItem(\"user\"));\r\n  if (!savedUser) return alert(\"Bạn chưa đăng nhập\");\r\n\r\n  try {\r\n    const res = await this.$axios.post(\"http://localhost:3000/comments\", {\r\n      post: this.post._id,\r\n      author: savedUser.username,\r\n      content: this.newComment\r\n    });\r\n\r\n    this.comments.unshift(res.data.comment); // thêm bình luận mới vào đầu danh sách\r\n    this.newComment = \"\";\r\n  } catch (err) {\r\n    console.error(\"Lỗi khi gửi bình luận:\", err);\r\n    alert(\"Không thể gửi bình luận\");\r\n  }\r\n},\r\n\r\n    replyTo(name) {\r\n      this.newComment = `@${name} `;\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadComments();\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.overlay {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  background: rgba(0, 0, 0, 0.6);\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  z-index: 2000;\r\n}\r\n.modal {\r\n  background: white;\r\n  padding: 20px;\r\n  border-radius: 10px;\r\n  width: 600px;\r\n  max-height: 90vh;\r\n  overflow-y: auto;\r\n}\r\n.post-header {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n  margin-bottom: 10px;\r\n}\r\n.post-header img {\r\n  width: 40px;\r\n  height: 40px;\r\n  border-radius: 50%;\r\n}\r\n.post-content {\r\n  margin-bottom: 10px;\r\n}\r\nimg,\r\nvideo {\r\n  width: 100%;\r\n  max-height: 400px;\r\n  object-fit: contain;\r\n  border-radius: 8px;\r\n  margin-bottom: 15px;\r\n}\r\n.comments {\r\n  background: #f5f5f5;\r\n  padding: 10px;\r\n  border-radius: 6px;\r\n  margin-bottom: 10px;\r\n}\r\n.comment {\r\n  margin-bottom: 8px;\r\n}\r\n.comment small {\r\n  color: #1877f2;\r\n  cursor: pointer;\r\n  font-size: 12px;\r\n}\r\n.comment-box {\r\n  display: flex;\r\n  gap: 10px;\r\n}\r\ninput {\r\n  flex: 1;\r\n  padding: 8px;\r\n  border-radius: 6px;\r\n  border: 1px solid #ccc;\r\n}\r\nbutton {\r\n  background: #1877f2;\r\n  color: white;\r\n  border: none;\r\n  padding: 8px 12px;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n}\r\n</style>\r\n"],"mappings":"AAyCA,eAAe;EACbA,KAAK,EAAE,CAAC,MAAM,CAAC;EACfC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,UAAU,EAAE,EAAE;MACdC,QAAQ,EAAE;IACZ,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,KAAKA,CAAA,EAAG;MACN,IAAI,CAACC,KAAK,CAAC,OAAO,CAAC;IACrB,CAAC;IACDC,UAAUA,CAACC,OAAO,EAAE;MAClB,OAAO,IAAIC,IAAI,CAACD,OAAO,CAAC,CAACE,cAAc,CAAC,CAAC;IAC3C,CAAC;IACDC,SAASA,CAACC,IAAI,EAAE;MACd,OAAOA,IAAG,GAAI,yBAAyBA,IAAI,EAAC,GAAI,oBAAoB;IACtE,CAAC;IACDC,QAAQA,CAACD,IAAI,EAAE;MACb,OAAO,yBAAyBA,IAAI,EAAE;IACxC,CAAC;IACD,MAAME,YAAYA,CAAA,EAAG;MACnB,IAAI;QACF,MAAMC,GAAE,GAAI,MAAM,IAAI,CAACC,MAAM,CAACC,GAAG,CAAC,mBAAmB,IAAI,CAACC,IAAI,CAACC,GAAG,EAAE,CAAC;QACrE,IAAI,CAAChB,QAAO,GAAIY,GAAG,CAACd,IAAI;MAC1B,EAAE,OAAOmB,GAAG,EAAE;QACZC,OAAO,CAACC,KAAK,CAAC,uBAAuB,EAAEF,GAAG,CAAC;MAC7C;IACF,CAAC;IACD,MAAMG,WAAWA,CAAA,EAAG;MACtB,IAAI,CAAC,IAAI,CAACrB,UAAU,CAACsB,IAAI,CAAC,CAAC,EAAE;MAE7B,MAAMC,SAAQ,GAAIC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,CAAC,CAAC;MAC1D,IAAI,CAACJ,SAAS,EAAE,OAAOK,KAAK,CAAC,oBAAoB,CAAC;MAElD,IAAI;QACF,MAAMf,GAAE,GAAI,MAAM,IAAI,CAACC,MAAM,CAACE,IAAI,CAAC,gCAAgC,EAAE;UACnEA,IAAI,EAAE,IAAI,CAACA,IAAI,CAACC,GAAG;UACnBY,MAAM,EAAEN,SAAS,CAACO,QAAQ;UAC1BC,OAAO,EAAE,IAAI,CAAC/B;QAChB,CAAC,CAAC;QAEF,IAAI,CAACC,QAAQ,CAAC+B,OAAO,CAACnB,GAAG,CAACd,IAAI,CAACkC,OAAO,CAAC,EAAE;QACzC,IAAI,CAACjC,UAAS,GAAI,EAAE;MACtB,EAAE,OAAOkB,GAAG,EAAE;QACZC,OAAO,CAACC,KAAK,CAAC,wBAAwB,EAAEF,GAAG,CAAC;QAC5CU,KAAK,CAAC,yBAAyB,CAAC;MAClC;IACF,CAAC;IAEGM,OAAOA,CAACC,IAAI,EAAE;MACZ,IAAI,CAACnC,UAAS,GAAI,IAAImC,IAAI,GAAG;IAC/B;EACF,C