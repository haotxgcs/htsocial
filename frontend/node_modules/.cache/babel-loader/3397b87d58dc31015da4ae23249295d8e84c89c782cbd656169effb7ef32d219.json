{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  data() {\n    return {\n      content: '',\n      image: null\n    };\n  },\n  methods: {\n    handleImageUpload(e) {\n      this.image = e.target.files[0];\n    },\n    async submitPost() {\n      try {\n        const savedUser = JSON.parse(localStorage.getItem('user'));\n        if (!savedUser) {\n          this.errorMsg = \"Bạn chưa đăng nhập!\";\n          return;\n        }\n        if (!this.content.trim()) {\n          this.errorMsg = \"Nội dung không được để trống!\";\n          return;\n        }\n        const formData = new FormData();\n        formData.append(\"content\", this.content);\n        formData.append(\"author\", savedUser.username);\n        if (this.image) {\n          formData.append(\"image\", this.image);\n        }\n        const response = await axios.post(\"http://localhost:3000/posts\", formData);\n        alert(\"Đăng bài thành công!\");\n        this.$router.push(\"/home\");\n      } catch (err) {\n        console.error(\"Post error:\", err);\n        this.errorMsg = err.response?.data?.msg || \"Đăng bài thất bại!\";\n      }\n    }\n  }\n};","map":{"version":3,"names":["data","content","image","methods","handleImageUpload","e","target","files","submitPost","savedUser","JSON","parse","localStorage","getItem","errorMsg","trim","formData","FormData","append","username","response","axios","post","alert","$router","push","err","console","error","msg"],"sources":["C:\\Users\\Yoga260\\Downloads\\Project\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\PostPage.vue"],"sourcesContent":["<!-- src/components/PostCreatePage.vue -->\r\n<template>\r\n  <div class=\"create-post-page\">\r\n    <h2>Tạo bài viết mới</h2>\r\n    <textarea v-model=\"content\" placeholder=\"Bạn đang nghĩ gì thế?\"></textarea>\r\n    <input type=\"file\" @change=\"handleImageUpload\" />\r\n    <button @click=\"submitPost\">Đăng bài</button>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  data() {\r\n    return {\r\n      content: '',\r\n      image: null\r\n    };\r\n  },\r\n  methods: {\r\n    handleImageUpload(e) {\r\n      this.image = e.target.files[0];\r\n    },\r\n    async submitPost() {\r\n  try {\r\n    const savedUser = JSON.parse(localStorage.getItem('user'));\r\n    if (!savedUser) {\r\n      this.errorMsg = \"Bạn chưa đăng nhập!\";\r\n      return;\r\n    }\r\n\r\n    if (!this.content.trim()) {\r\n      this.errorMsg = \"Nội dung không được để trống!\";\r\n      return;\r\n    }\r\n\r\n    const formData = new FormData();\r\n    formData.append(\"content\", this.content);\r\n    formData.append(\"author\", savedUser.username);\r\n    if (this.image) {\r\n      formData.append(\"image\", this.image);\r\n    }\r\n\r\n    const response = await axios.post(\"http://localhost:3000/posts\", formData);\r\n    alert(\"Đăng bài thành công!\");\r\n    this.$router.push(\"/home\");\r\n\r\n  } catch (err) {\r\n    console.error(\"Post error:\", err);\r\n    this.errorMsg = err.response?.data?.msg || \"Đăng bài thất bại!\";\r\n  }\r\n}\r\n\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.create-post-page {\r\n  max-width: 600px;\r\n  margin: 40px auto;\r\n  background: #fff;\r\n  padding: 20px;\r\n  border-radius: 12px;\r\n}\r\ntextarea {\r\n  width: 100%;\r\n  height: 100px;\r\n  margin-bottom: 12px;\r\n}\r\n</style>\r\n"],"mappings":";AAWA,eAAe;EACbA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,EAAE;MACXC,KAAK,EAAE;IACT,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,iBAAiBA,CAACC,CAAC,EAAE;MACnB,IAAI,CAACH,KAAI,GAAIG,CAAC,CAACC,MAAM,CAACC,KAAK,CAAC,CAAC,CAAC;IAChC,CAAC;IACD,MAAMC,UAAUA,CAAA,EAAG;MACrB,IAAI;QACF,MAAMC,SAAQ,GAAIC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,CAAC,CAAC;QAC1D,IAAI,CAACJ,SAAS,EAAE;UACd,IAAI,CAACK,QAAO,GAAI,qBAAqB;UACrC;QACF;QAEA,IAAI,CAAC,IAAI,CAACb,OAAO,CAACc,IAAI,CAAC,CAAC,EAAE;UACxB,IAAI,CAACD,QAAO,GAAI,+BAA+B;UAC/C;QACF;QAEA,MAAME,QAAO,GAAI,IAAIC,QAAQ,CAAC,CAAC;QAC/BD,QAAQ,CAAC