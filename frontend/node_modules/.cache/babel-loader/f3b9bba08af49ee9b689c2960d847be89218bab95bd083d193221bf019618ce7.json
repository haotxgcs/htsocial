{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'MainHeader',\n  data() {\n    return {\n      showMessageDropdown: false,\n      showNotificationDropdown: false,\n      notifications: [\"Bạn có 1 lời mời kết bạn\", \"Hào đã like bài viết của bạn\", \"Bảo đã chia sẻ bài viết của bạn\"]\n    };\n  },\n  methods: {\n    toggleMessage() {\n      this.showMessageDropdown = !this.showMessageDropdown;\n      this.showNotificationDropdown = false;\n    },\n    toggleNotification() {\n      this.showNotificationDropdown = !this.showNotificationDropdown;\n      this.showMessageDropdown = false;\n    },\n    async logout() {\n      const user = JSON.parse(localStorage.getItem(\"user\"));\n      const token = localStorage.getItem(\"token\");\n      if (user && token) {\n        try {\n          await fetch(\"http://localhost:3000/users/logout\", {\n            method: \"POST\",\n            headers: {\n              \"Content-Type\": \"application/json\",\n              Authorization: `Bearer ${token}`\n            },\n            body: JSON.stringify({\n              userId: user.id\n            })\n          });\n        } catch (err) {\n          console.error(\"Logout error:\", err);\n        }\n      }\n\n      // Xoá localStorage\n      localStorage.removeItem(\"user\");\n      localStorage.removeItem(\"token\");\n\n      // Chuyển về trang đăng nhập\n      this.$router.push(\"/login\");\n    }\n  }\n};","map":{"version":3,"names":["name","data","showMessageDropdown","showNotificationDropdown","notifications","methods","toggleMessage","toggleNotification","logout","user","JSON","parse","localStorage","getItem","token","fetch","method","headers","Authorization","body","stringify","userId","id","err","console","error","removeItem","$router","push"],"sources":["C:\\Users\\Yoga260\\Downloads\\Project\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\Header.vue"],"sourcesContent":["<template>\r\n  <header class=\"header\">\r\n    <!-- Left: Logo + Search -->\r\n    <div class=\"left\">\r\n      <router-link to=\"/home\">\r\n        <img src=\"../assets/htsocial.png\" alt=\"Logo\" class=\"logo\" />\r\n      </router-link>\r\n      <input type=\"text\" placeholder=\"Search on HT Social...\" class=\"search\" />\r\n    </div>\r\n\r\n    <!-- Center: Navigation Icons -->\r\n    <div class=\"center\">\r\n      <router-link to=\"/home\" class=\"nav-icon\" active-class=\"active\">\r\n        <img src=\"../assets/home.png\" class=\"icon-img\" />\r\n      </router-link>\r\n      <router-link to=\"/friend\" class=\"nav-icon\" active-class=\"active\">\r\n        <img src=\"../assets/friend.png\" class=\"icon-img\" />\r\n      </router-link>\r\n      <router-link to=\"/marketplace\" class=\"nav-icon\" active-class=\"active\">\r\n        <img src=\"../assets/marketplace.png\" class=\"icon-img\" />\r\n      </router-link>\r\n      <router-link to=\"/group\" class=\"nav-icon\" active-class=\"active\">\r\n        <img src=\"../assets/group.png\" class=\"icon-img\" />\r\n      </router-link>\r\n      <router-link to=\"/game\" class=\"nav-icon\" active-class=\"active\">\r\n        <img src=\"../assets/game.png\" class=\"icon-img\" />\r\n      </router-link>\r\n    </div>\r\n\r\n    <!-- Right: Actions -->\r\n    <div class=\"right\">\r\n      <div class=\"icon-circle\">\r\n        <img src=\"../assets/menu.png\" class=\"icon-img\" />\r\n      </div>\r\n\r\n    <!-- Message Dropdown -->\r\n    <div class=\"icon-circle\" @click=\"toggleMessage\">\r\n      <img src=\"../assets/message.png\" class=\"icon-img\" />\r\n      <div v-if=\"showMessageDropdown\" class=\"dropdown-panel\">\r\n        <h4>Tin nhắn</h4>\r\n        <input type=\"text\" v-model=\"search\" placeholder=\"Tìm bạn bè...\" class=\"search-input\" />\r\n        <ul>\r\n          <li \r\n            v-for=\"friend in filteredFriends\" \r\n            :key=\"friend._id\"\r\n            @click=\"goToChat(friend)\"\r\n          >\r\n            {{ friend.firstname }} {{ friend.lastname }}\r\n          </li>\r\n        </ul>\r\n      </div>\r\n</div>\r\n\r\n\r\n<!-- Notification Dropdown -->\r\n<div class=\"icon-circle notification\" @click=\"toggleNotification\">\r\n  <img src=\"../assets/notification.png\" class=\"icon-img\" />\r\n  <!-- <span class=\"badge\">1</span> -->\r\n  <div v-if=\"showNotificationDropdown\" class=\"dropdown-panel\">\r\n    <h4>Notifications</h4>\r\n    <ul>\r\n      <li v-for=\"(noti, index) in notifications\" :key=\"index\">{{ noti }}</li>\r\n    </ul>\r\n  </div>\r\n</div>\r\n\r\n\r\n      <router-link to=\"/profile\" class=\"icon-circle\">\r\n        <img src=\"../assets/user.png\" class=\"avatar-image\" />\r\n      </router-link>\r\n    </div>\r\n\r\n<div class=\"icon-circle\" @click=\"logout\">\r\n<img src=\"../assets/logout.png\" class=\"icon-img\" />\r\n</div>\r\n    \r\n\r\n  </header>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'MainHeader',\r\n  data() {\r\n    return {\r\n      showMessageDropdown: false,\r\n      showNotificationDropdown: false,\r\n      \r\n      notifications: [\r\n        \"Bạn có 1 lời mời kết bạn\",\r\n        \"Hào đã like bài viết của bạn\",\r\n        \"Bảo đã chia sẻ bài viết của bạn\"\r\n      ]\r\n    };\r\n  },\r\n  methods: {\r\n    toggleMessage() {\r\n      this.showMessageDropdown = !this.showMessageDropdown;\r\n      this.showNotificationDropdown = false;\r\n    },\r\n    toggleNotification() {\r\n      this.showNotificationDropdown = !this.showNotificationDropdown;\r\n      this.showMessageDropdown = false;\r\n    },\r\n    async logout() {\r\n      const user = JSON.parse(localStorage.getItem(\"user\"));\r\n      const token = localStorage.getItem(\"token\");\r\n\r\n      if (user && token) {\r\n        try {\r\n          await fetch(\"http://localhost:3000/users/logout\", {\r\n            method: \"POST\",\r\n            headers: {\r\n              \"Content-Type\": \"application/json\",\r\n              Authorization: `Bearer ${token}`\r\n            },\r\n            body: JSON.stringify({ userId: user.id })\r\n          });\r\n        } catch (err) {\r\n          console.error(\"Logout error:\", err);\r\n        }\r\n      }\r\n\r\n      // Xoá localStorage\r\n      localStorage.removeItem(\"user\");\r\n      localStorage.removeItem(\"token\");\r\n\r\n      // Chuyển về trang đăng nhập\r\n      this.$router.push(\"/login\");\r\n    }\r\n  }\r\n};\r\n\r\n</script>\r\n\r\n\r\n<style scoped>\r\n.header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  background: white;\r\n  height: 56px;\r\n  padding: 0 16px;\r\n  border-bottom: 1px solid #ccc;\r\n  position: sticky;\r\n  top: 0;\r\n  z-index: 10;\r\n}\r\n.left {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n.logo {\r\n  height: 36px;\r\n  margin-right: 12px;\r\n}\r\n.search {\r\n  background: #f0f2f5;\r\n  border: none;\r\n  padding: 8px 12px;\r\n  border-radius: 999px;\r\n  font-size: 14px;\r\n  width: 220px;\r\n}\r\n.center {\r\n  flex: 2;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  gap: 40px;\r\n}\r\n.nav-icon {\r\n  width: 45px;\r\n  height: 45px;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  border-radius: 10px;\r\n  cursor: pointer;\r\n  transition: background 0.2s ease;\r\n}\r\n.nav-icon:hover {\r\n  background-color: #f0f2f5;\r\n}\r\n.nav-icon.active {\r\n  border-bottom: 3px solid #1877f2;\r\n  background-color: #f0f2f5;\r\n}\r\n.icon-img {\r\n  width: 24px;\r\n  height: 24px;\r\n  object-fit: contain;\r\n}\r\n.right {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n}\r\n.icon-circle {\r\n  background: #e4e6eb;\r\n  width: 36px;\r\n  height: 36px;\r\n  border-radius: 50%;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  cursor: pointer;\r\n  position: relative;\r\n}\r\n.badge {\r\n  position: absolute;\r\n  top: -2px;\r\n  right: -2px;\r\n  background: red;\r\n  color: white;\r\n  font-size: 10px;\r\n  border-radius: 999px;\r\n  padding: 2px 5px;\r\n}\r\n.avatar-image {\r\n  width: 28px;\r\n  height: 28px;\r\n  border-radius: 999px;\r\n  object-fit: cover;\r\n}\r\n\r\n.dropdown-panel {\r\n  position: absolute;\r\n  top: 50px;\r\n  right: 0;\r\n  width: 300px;\r\n  background: white;\r\n  border: 1px solid #ccc;\r\n  box-shadow: 0 2px 8px rgba(0,0,0,0.2);\r\n  border-radius: 8px;\r\n  z-index: 999;\r\n  padding: 10px;\r\n}\r\n\r\n.dropdown-panel h4 {\r\n  margin-bottom: 10px;\r\n  font-size: 16px;\r\n}\r\n\r\n.dropdown-panel ul {\r\n  list-style: none;\r\n  padding: 0;\r\n  margin: 0;\r\n  max-height: 250px;\r\n  overflow-y: auto;\r\n}\r\n\r\n.dropdown-panel li {\r\n  padding: 8px 6px;\r\n  border-bottom: 1px solid #eee;\r\n  font-size: 14px;\r\n  cursor: pointer;\r\n}\r\n\r\n.dropdown-panel li:hover {\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.search-input {\r\n  width: 100%;\r\n  padding: 6px 8px;\r\n  border: 1px solid #ccc;\r\n  border-radius: 4px;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n\r\n\r\n</style>\r\n"],"mappings":";AAiFA,eAAe;EACbA,IAAI,EAAE,YAAY;EAClBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,mBAAmB,EAAE,KAAK;MAC1BC,wBAAwB,EAAE,KAAK;MAE/BC,aAAa,EAAE,CACb,0BAA0B,EAC1B,8BAA8B,EAC9B,iCAAgC;IAEpC,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,aAAaA,CAAA,EAAG;MACd,IAAI,CAACJ,mBAAkB,GAAI,CAAC,IAAI,CAACA,mBAAmB;MACpD,IAAI,CAACC,wBAAuB,GAAI,KAAK;IACvC,CAAC;IACDI,kBAAkBA,CAAA,EAAG;MACnB,IAAI,CAACJ,wBAAuB,GAAI,CAAC,IAAI,CAACA,wBAAwB;MAC9D,IAAI,CAACD,mBAAkB,GAAI,KAAK;IAClC,CAAC;IACD,MAAMM,MAAMA,CAAA,EAAG;MACb,MAAMC,IAAG,GAAIC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,CAAC,CAAC;MACrD,MAAMC,KAAI,GAAIF,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;MAE3C,IAAIJ,IAAG,IAAKK,KAAK,EAAE;QACjB,IAAI;UACF,MAAMC,KAAK,CAAC,oCAAoC,EAAE;YAChDC,MAAM,EAAE,MAAM;YACdC,OAAO,EAAE;cACP,cAAc,EAAE,kBAAkB;cAClCC,aAAa,EAAE,UAAUJ,KAAK;YAChC,CAAC;YACDK,IAAI,EAAET,IAAI,CAACU,SAAS,CAAC;cAAEC,MAAM,EAAEZ,IAAI,CAACa;YAAG,CAAC;UAC1C,CAAC,CAAC;QACJ,EAAE,OAAOC,GAAG,EAAE;UACZC,OAAO,CAACC,KAAK,CAAC,eAAe,EAAEF,GAAG,CAAC;QACrC;MACF;;MAEA;MACAX,YAAY,CAACc,UAAU,CAAC,MAAM,CAAC;MAC/Bd,YAAY,CAACc,UAAU,CAAC,OAAO,CAAC;;MAEhC;MACA,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,QAAQ,CAAC;IAC7B;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}