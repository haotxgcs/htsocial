{"ast":null,"code":"export default {\n  props: [\"post\"],\n  data() {\n    return {\n      newComment: \"\",\n      comments: []\n    };\n  },\n  methods: {\n    close() {\n      this.$emit(\"close\");\n    },\n    formatTime(dateStr) {\n      return new Date(dateStr).toLocaleString();\n    },\n    getAvatar(path) {\n      return path ? `http://localhost:3000/${path}` : \"../assets/user.png\";\n    },\n    getMedia(path) {\n      return `http://localhost:3000/${path}`;\n    },\n    async sendComment() {\n      const savedUser = JSON.parse(localStorage.getItem(\"user\"));\n      if (!this.newComment.trim() || !savedUser) return;\n      try {\n        await this.$axios.post('/comments', {\n          post: this.post._id,\n          author: savedUser.id,\n          content: this.newComment.trim()\n        });\n        this.newComment = \"\";\n        this.loadComments(); // Gọi lại API để lấy danh sách mới\n      } catch (err) {\n        console.error(\"Lỗi khi gửi comment:\", err);\n        alert(\"Không thể gửi bình luận!\");\n      }\n    },\n    replyTo(name) {\n      this.newComment = `@${name} `;\n    },\n    async loadComments() {\n      try {\n        const res = await this.$axios.get(`/comments/posts/${this.post._id}`);\n        this.comments = res.data;\n      } catch (err) {\n        console.error(\"Lỗi khi tải comments:\", err);\n      }\n    },\n    mounted() {\n      this.loadComments();\n    }\n  }\n};","map":{"version":3,"names":["props","data","newComment","comments","methods","close","$emit","formatTime","dateStr","Date","toLocaleString","getAvatar","path","getMedia","sendComment","savedUser","JSON","parse","localStorage","getItem","trim","$axios","post","_id","author","id","content","loadComments","err","console","error","alert","replyTo","name","res","get","mounted"],"sources":["C:\\Users\\Yoga260\\Downloads\\Project\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\PostDetailModal.vue"],"sourcesContent":["<template>\r\n  <div class=\"overlay\" @click.self=\"close\">\r\n    <div class=\"modal\">\r\n      <!-- Header -->\r\n      <div class=\"post-header\">\r\n        <img :src=\"getAvatar(post?.author?.avatar)\" />\r\n        <div>\r\n          <strong>{{ post?.author?.firstname }} {{ post?.author?.lastname }}</strong>\r\n          <p>{{ formatTime(post?.createdAt) }}</p>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Nội dung -->\r\n      <p class=\"post-content\">{{ post?.content }}</p>\r\n\r\n      <!-- Media -->\r\n      <div v-if=\"post?.media\">\r\n        <img v-if=\"post?.mediaType === 'image'\" :src=\"getMedia(post.media)\" />\r\n        <video v-else controls><source :src=\"getMedia(post.media)\" type=\"video/mp4\" /></video>\r\n      </div>\r\n\r\n      <!-- Comment list -->\r\n      <div class=\"comments\">\r\n        <div v-for=\"(c, index) in comments\" :key=\"index\" class=\"comment\">\r\n          <p><strong>{{ c.user }}:</strong> {{ c.content }}</p>\r\n          <small @click=\"replyTo(c.user)\">↳ Trả lời</small>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Bình luận -->\r\n      <div class=\"comment-box\">\r\n        <input v-model=\"newComment\" placeholder=\"Viết bình luận...\" />\r\n        <button @click=\"sendComment\">Gửi</button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  props: [\"post\"],\r\n  data() {\r\n    return {\r\n      newComment: \"\",\r\n      comments: [\r\n      ]\r\n    };\r\n  },\r\n  methods: {\r\n    close() {\r\n      this.$emit(\"close\");\r\n    },\r\n    formatTime(dateStr) {\r\n      return new Date(dateStr).toLocaleString();\r\n    },\r\n    getAvatar(path) {\r\n      return path ? `http://localhost:3000/${path}` : \"../assets/user.png\";\r\n    },\r\n    getMedia(path) {\r\n      return `http://localhost:3000/${path}`;\r\n    },\r\n\r\n    async sendComment() {\r\n  const savedUser = JSON.parse(localStorage.getItem(\"user\"));\r\n  if (!this.newComment.trim() || !savedUser) return;\r\n\r\n  try {\r\n    await this.$axios.post('/comments', {\r\n      post: this.post._id,\r\n      author: savedUser.id,\r\n      content: this.newComment.trim()\r\n    });\r\n\r\n    this.newComment = \"\";\r\n    this.loadComments(); // Gọi lại API để lấy danh sách mới\r\n  } catch (err) {\r\n    console.error(\"Lỗi khi gửi comment:\", err);\r\n    alert(\"Không thể gửi bình luận!\");\r\n  }\r\n},\r\n    replyTo(name) {\r\n      this.newComment = `@${name} `;\r\n    },\r\n\r\n    async loadComments() {\r\n  try {\r\n    const res = await this.$axios.get(`/comments/posts/${this.post._id}`);\r\n    this.comments = res.data;\r\n  } catch (err) {\r\n    console.error(\"Lỗi khi tải comments:\", err);\r\n  }\r\n},\r\nmounted() {\r\n  this.loadComments();\r\n}\r\n\r\n\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.overlay {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  background: rgba(0,0,0,0.6);\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  z-index: 2000;\r\n}\r\n.modal {\r\n  background: white;\r\n  padding: 20px;\r\n  border-radius: 10px;\r\n  width: 600px;\r\n  max-height: 90vh;\r\n  overflow-y: auto;\r\n}\r\n\r\n.post-header {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n  margin-bottom: 10px;\r\n}\r\n.post-header img {\r\n  width: 40px;\r\n  height: 40px;\r\n  border-radius: 50%;\r\n}\r\n.post-content {\r\n  margin-bottom: 10px;\r\n}\r\nimg, video {\r\n  width: 100%;\r\n  max-height: 400px;\r\n  object-fit: contain;\r\n  border-radius: 8px;\r\n  margin-bottom: 15px;\r\n}\r\n.comments {\r\n  background: #f5f5f5;\r\n  padding: 10px;\r\n  border-radius: 6px;\r\n  margin-bottom: 10px;\r\n}\r\n.comment {\r\n  margin-bottom: 8px;\r\n}\r\n.comment small {\r\n  color: #1877f2;\r\n  cursor: pointer;\r\n  font-size: 12px;\r\n}\r\n.comment-box {\r\n  display: flex;\r\n  gap: 10px;\r\n}\r\ninput {\r\n  flex: 1;\r\n  padding: 8px;\r\n  border-radius: 6px;\r\n  border: 1px solid #ccc;\r\n}\r\nbutton {\r\n  background: #1877f2;\r\n  color: white;\r\n  border: none;\r\n  padding: 8px 12px;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n}\r\n</style>\r\n"],"mappings":"AAuCA,eAAe;EACbA,KAAK,EAAE,CAAC,MAAM,CAAC;EACfC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,UAAU,EAAE,EAAE;MACdC,QAAQ,EAAE;IAEZ,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,KAAKA,CAAA,EAAG;MACN,IAAI,CAACC,KAAK,CAAC,OAAO,CAAC;IACrB,CAAC;IACDC,UAAUA,CAACC,OAAO,EAAE;MAClB,OAAO,IAAIC,IAAI,CAACD,OAAO,CAAC,CAACE,cAAc,CAAC,CAAC;IAC3C,CAAC;IACDC,SAASA,CAACC,IAAI,EAAE;MACd,OAAOA,IAAG,GAAI,yBAAyBA,IAAI,EAAC,GAAI,oBAAoB;IACtE,CAAC;IACDC,QAAQA,CAACD,IAAI,EAAE;MACb,OAAO,yBAAyBA,IAAI,EAAE;IACxC,CAAC;IAED,MAAME,WAAWA,CAAA,EAAG;MACtB,MAAMC,SAAQ,GAAIC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,CAAC,CAAC;MAC1D,IAAI,CAAC,IAAI,CAACjB,UAAU,CAACkB,IAAI,CAAC,KAAK,CAACL,SAAS,EAAE;MAE3C,IAAI;QACF,MAAM,IAAI,CAACM,MAAM,CAACC,IAAI,CAAC,WAAW,EAAE;UAClCA,IAAI,EAAE,IAAI,CAACA,IAAI,CAACC,GAAG;UACnBC,MAAM,EAAET,SAAS,CAACU,EAAE;UACpBC,OAAO,EAAE,IAAI,CAACxB,UAAU,CAACkB,IAAI,CAAC;QAChC,CAAC,CAAC;QAEF,IAAI,CAAClB,UAAS,GAAI,EAAE;QACpB,IAAI,CAACyB,YAAY,CAAC,CAAC,EAAE;MACvB,EAAE,OAAOC,GAAG,EAAE;QACZC,OAAO,CAACC,KAAK,CAAC,sBAAsB,EAAEF,GAAG,CAAC;QAC1CG,KAAK,CAAC,0BAA0B,CAAC;MACnC;IACF,CAAC;IACGC,OAAOA,CAACC,IAAI,EAAE;MACZ,IAAI,CAAC/B,UAAS,GAAI,IAAI+B,IAAI,GAAG;IAC/B,CAAC;IAED,MAAMN,YAAYA,CAAA,EAAG;MACvB,IAAI;QACF,MAAMO,GAAE,GAAI,MAAM,IAAI,CAACb,MAAM,CAACc,GAAG,CAAC,mBAAmB,IAAI,CAACb,IAAI,CAACC,GAAG,EAAE,CAAC;QACrE,IAAI,CAACpB,QAAO,GAAI+B,GAAG,CAACjC,IAAI;MAC1B,EAAE,OAAO2B,GAAG,EAAE;QACZC,OAAO,CAACC,KAAK,CAAC,uBAAuB,EAAEF,GAAG,CAAC;MAC7C;IACF,CAAC;IACDQ,OAAOA,CAAA,EAAG;MACR,IAAI,CAACT,YAAY,CAAC,CAAC;IACrB;EAGE;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}