{"ast":null,"code":"export default {\n  name: 'PostPage',\n  data() {\n    return {\n      post: null\n    };\n  },\n  mounted() {\n    const postId = this.$route.params.id;\n    fetch(`http://localhost:3000/posts/${postId}`).then(res => res.json()).then(data => {\n      this.post = data;\n    });\n  },\n  methods: {\n    likePost() {\n      alert(\"Bạn đã thích bài viết!\");\n    },\n    commentPost() {\n      alert(\"Bạn muốn bình luận bài viết.\");\n    },\n    sharePost() {\n      alert(\"Bạn đã chia sẻ bài viết!\");\n    },\n    formatDate(dateStr) {\n      const date = new Date(dateStr);\n      return date.toLocaleString();\n    }\n  }\n};","map":{"version":3,"names":["name","data","post","mounted","postId","$route","params","id","fetch","then","res","json","methods","likePost","alert","commentPost","sharePost","formatDate","dateStr","date","Date","toLocaleString"],"sources":["C:\\Users\\Yoga260\\Downloads\\Project\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\PostPage.vue"],"sourcesContent":["<template>\r\n  <div class=\"post-page\">\r\n    <h2>Bài viết</h2>\r\n    <div v-if=\"post\">\r\n      <div class=\"post-header\">\r\n        <img :src=\"post.author?.avatar || '/default-avatar.png'\" class=\"avatar\" />\r\n        <div>\r\n          <strong>{{ post.author?.firstname }} {{ post.author?.lastname }}</strong>\r\n          <p class=\"time\">{{ formatDate(post.createdAt) }}</p>\r\n        </div>\r\n      </div>\r\n      <p class=\"content\">{{ post.content }}</p>\r\n      <img v-if=\"post.image\" :src=\"post.image\" class=\"post-image\" />\r\n\r\n      <div class=\"post-actions\">\r\n        <button @click=\"likePost\">👍 Like</button>\r\n        <button @click=\"commentPost\">💬 Comment</button>\r\n        <button @click=\"sharePost\">🔁 Share</button>\r\n      </div>\r\n    </div>\r\n    <div v-else>\r\n      <p>Đang tải bài viết...</p>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'PostPage',\r\n  data() {\r\n    return {\r\n      post: null\r\n    };\r\n  },\r\n  mounted() {\r\n    const postId = this.$route.params.id;\r\n    fetch(`http://localhost:3000/posts/${postId}`)\r\n      .then(res => res.json())\r\n      .then(data => {\r\n        this.post = data;\r\n      });\r\n  },\r\n  methods: {\r\n    likePost() {\r\n      alert(\"Bạn đã thích bài viết!\");\r\n    },\r\n    commentPost() {\r\n      alert(\"Bạn muốn bình luận bài viết.\");\r\n    },\r\n    sharePost() {\r\n      alert(\"Bạn đã chia sẻ bài viết!\");\r\n    },\r\n    formatDate(dateStr) {\r\n      const date = new Date(dateStr);\r\n      return date.toLocaleString();\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.post-page {\r\n  max-width: 600px;\r\n  margin: 20px auto;\r\n  background: white;\r\n  padding: 20px;\r\n  border-radius: 8px;\r\n}\r\n.post-header {\r\n  display: flex;\r\n  align-items: center;\r\n  margin-bottom: 10px;\r\n}\r\n.avatar {\r\n  width: 40px;\r\n  height: 40px;\r\n  border-radius: 50%;\r\n  margin-right: 10px;\r\n}\r\n.time {\r\n  color: gray;\r\n  font-size: 12px;\r\n}\r\n.content {\r\n  margin: 10px 0;\r\n  font-size: 14px;\r\n}\r\n.post-image {\r\n  width: 100%;\r\n  border-radius: 10px;\r\n  margin-top: 10px;\r\n}\r\n.post-actions {\r\n  display: flex;\r\n  justify-content: space-around;\r\n  margin-top: 10px;\r\n  border-top: 1px solid #ddd;\r\n  padding-top: 10px;\r\n}\r\n.post-actions button {\r\n  background: none;\r\n  border: none;\r\n  color: #555;\r\n  cursor: pointer;\r\n  font-weight: bold;\r\n}\r\n.post-actions button:hover {\r\n  color: #1877f2;\r\n}\r\n</style>\r\n"],"mappings":"AA2BA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,IAAI,EAAE;IACR,CAAC;EACH,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,MAAMC,MAAK,GAAI,IAAI,CAACC,MAAM,CAACC,MAAM,CAACC,EAAE;IACpCC,KAAK,CAAC,+BAA+BJ,MAAM,EAAE,EAC1CK,IAAI,CAACC,GAAE,IAAKA,GAAG,CAACC,IAAI,CAAC,CAAC,EACtBF,IAAI,CAACR,IAAG,IAAK;MACZ,IAAI,CAACC,IAAG,GAAID,IAAI;IAClB,CAAC,CAAC;EACN,CAAC;EAC