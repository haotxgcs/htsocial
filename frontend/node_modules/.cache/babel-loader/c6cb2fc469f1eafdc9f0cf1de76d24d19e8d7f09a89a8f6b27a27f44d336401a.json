n            <span>Buying</span>\r\n            <i class=\"fas fa-chevron-right\"></i>\r\n          </div>\r\n          <div class=\"menu-item\">\r\n            <i class=\"fas fa-tag\"></i>\r\n            <span>Selling</span>\r\n            <i class=\"fas fa-chevron-right\"></i>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"create-listing\">\r\n          <i class=\"fas fa-plus\"></i>\r\n          <span>Create new listing</span>\r\n        </div>\r\n\r\n        <div class=\"location-section\">\r\n          <h3>Location</h3>\r\n          <p>Kiên Tân, Kiền Giang, Vietnam • Within 65 km</p>\r\n        </div>\r\n\r\n        <div class=\"categories-section\">\r\n          <h3>Categories</h3>\r\n          <div class=\"category-item\">\r\n            <i class=\"fas fa-car\"></i>\r\n            <span>Vehicles</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Main Content -->\r\n      <div class=\"main-content\">\r\n        <div class=\"content-header\">\r\n          <h2>Today's picks</h2>\r\n          <div class=\"location-badge\">\r\n            <i class=\"fas fa-map-marker-alt\"></i>\r\n            <span>Huyện Tân Hiệp • 65 km</span>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Products Grid -->\r\n        <div class=\"products-grid\">\r\n          <div v-for=\"product in products\" :key=\"product.id\" class=\"product-card\">\r\n            <div class=\"product-image\">\r\n              <img :src=\"product.image\" :alt=\"product.name\">\r\n            </div>\r\n            <div class=\"product-info\">\r\n              <div class=\"product-price\">{{ product.price }}</div>\r\n              <div class=\"product-name\">{{ product.name }}</div>\r\n              <div class=\"product-location\">{{ product.location }}</div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"MarketplacePage\",\r\n  data() {\r\n    return {\r\n      searchQuery: '',\r\n      products: [\r\n        {\r\n          id: 1,\r\n          name: 'Oppo reno 12 5g (12-256gb)',\r\n          price: 'đ5,999',\r\n          image: 'https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=300&h=300&fit=crop',\r\n          location: 'Long Xuyên'\r\n        },\r\n        {\r\n          id: 2,\r\n          name: 'S6 lite zin chạy mượt ko lỗi!!! Gl dt gaming',\r\n          price: 'đ2,500,000',\r\n          image: 'https://images.unsplash.com/photo-1544244015-0df4b3ffc6b0?w=300&h=300&fit=crop',\r\n          location: 'Huyện Châu Thành, Kiền Giang, Vietnam'\r\n        },\r\n        {\r\n          id: 3,\r\n          name: 'Oppo reno 6z 5g full zin đẹp',\r\n          price: 'đ2,800',\r\n          image: 'https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=300&h=300&fit=crop',\r\n          location: 'Châu Phú, An Giang, Vietnam'\r\n        },\r\n        {\r\n          id: 4,\r\n          name: 'Cần psss',\r\n          price: 'đ3,500,000',\r\n          image: 'https://images.unsplash.com/photo-1592750475338-74b7b21085ab?w=300&h=300&fit=crop',\r\n          location: 'Cần Thơ'\r\n        },\r\n        {\r\n          id: 5,\r\n          name: 'Camera lens',\r\n          price: 'đ1,200,000',\r\n          image: 'https://images.unsplash.com/photo-1606983340126-99ab4feaa64a?w=300&h=300&fit=crop',\r\n          location: 'TP.HCM'\r\n        },\r\n        {\r\n          id: 6,\r\n          name: 'iPhone 12 Pro Max',\r\n          price: 'đ15,999,000',\r\n          image: 'https://images.unsplash.com/photo-1592750475338-74b7b21085ab?w=300&h=300&fit=crop',\r\n          location: 'Hà Nội'\r\n        },\r\n        {\r\n          id: 7,\r\n          name: 'Shimano Malaysia fishing reel',\r\n          price: 'đ850,000',\r\n          image: 'https://images.unsplash.com/photo-1544966503-7cc5ac882d5f?w=300&h=300&fit=crop',\r\n          location: 'Cần Thơ'\r\n        },\r\n        {\r\n          id: 8,\r\n          name: 'Gaming setup complete',\r\n          price: 'đ12,500,000',\r\n          image: 'https://images.unsplash.com/photo-1593640408182-31c70c8268f5?w=300&h=300&fit=crop',\r\n          location: 'TP.HCM'\r\n        }\r\n      ]\r\n    }\r\n  },\r\n  mounted() {\r\n    const user = JSON.parse(sessionStorage.getItem(\"user\") || localStorage.getItem(\"user\") || \"null\");\r\n    if (!user) {\r\n      return this.$router.push(\"/login\");\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.marketplace-container {\r\n  background-color: #f0f2f5;\r\n  min-height: 100vh;\r\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\r\n}\r\n\r\n.marketplace-layout {\r\n  display: flex;\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n}\r\n\r\n/* Sidebar */\r\n.sidebar {\r\n  width: 360px;\r\n  background: white;\r\n  height: 100vh;\r\n  padding: 20px;\r\n  border-right: 1px solid #dadde1;\r\n  position: fixed;\r\n  left: 0;\r\n  top: 0;\r\n  overflow-y: auto;\r\n}\r\n\r\n.sidebar-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.marketplace-title {\r\n  font-size: 24px;\r\n  font-weight: 700;\r\n  color: #1c1e21;\r\n  margin: 0;\r\n}\r\n\r\n.settings-icon {\r\n  font-size: 20px;\r\n  color: #65676b;\r\n  cursor: pointer;\r\n  padding: 8px;\r\n  border-radius: 50%;\r\n}\r\n\r\n.settings-icon:hover {\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.search-container {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.search-bar {\r\n  position: relative;\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.search-bar i {\r\n  position: absolute;\r\n  left: 12px;\r\n  color: #65676b;\r\n  z-index: 1;\r\n}\r\n\r\n.search-bar input {\r\n  width: 100%;\r\n  padding: 10px 16px 10px 40px;\r\n  border: none;\r\n  border-radius: 50px;\r\n  background-color: #f0f2f5;\r\n  font-size: 15px;\r\n  outline: none;\r\n}\r\n\r\n.search-bar input:focus {\r\n  background-color: white;\r\n  box-shadow: 0 0 0 2px #1877f2;\r\n}\r\n\r\n.sidebar-menu {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.menu-item {\r\n  display: flex;\r\n  align-items: center;\r\n  padding: 8px 12px;\r\n  border-radius: 8px;\r\n  cursor: pointer;\r\n  font-size: 15px;\r\n  color: #1c1e21;\r\n  margin-bottom: 4px;\r\n  position: relative;\r\n}\r\n\r\n.menu-item:hover {\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.menu-item.active {\r\n  background-color: #e7f3ff;\r\n  color: #1877f2;\r\n}\r\n\r\n.menu-item i:first-child {\r\n  width: 20px;\r\n  margin-right: 12px;\r\n}\r\n\r\n.menu-item .fa-chevron-right {\r\n  position: absolute;\r\n  right: 12px;\r\n  font-size: 12px;\r\n  color: #65676b;\r\n}\r\n\r\n.create-listing {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  padding: 10px;\r\n  background-color: #1877f2;\r\n  color: white;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n  font-size: 15px;\r\n  font-weight: 600;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.create-listing:hover {\r\n  background-color: #166fe5;\r\n}\r\n\r\n.create-listing i {\r\n  margin-right: 8px;\r\n}\r\n\r\n.location-section,\r\n.categories-section {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.location-section h3,\r\n.categories-section h3 {\r\n  font-size: 17px;\r\n  font-weight: 600;\r\n  color: #1c1e21;\r\n  margin: 0 0 12px 0;\r\n}\r\n\r\n.location-section p {\r\n  color: #65676b;\r\n  font-size: 14px;\r\n  margin: 0;\r\n}\r\n\r\n.category-item {\r\n  display: flex;\r\n  align-items: center;\r\n  padding: 8px 12px;\r\n  border-radius: 8px;\r\n  cursor: pointer;\r\n  font-size: 15px;\r\n  color: #1c1e21;\r\n}\r\n\r\n.category-item:hover {\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.category-item i {\r\n  width: 20px;\r\n  margin-right: 12px;\r\n  color: #65676b;\r\n}\r\n\r\n/* Main Content */\r\n.main-content {\r\n  flex: 1;\r\n  margin-left: 360px;\r\n  padding: 20px;\r\n}\r\n\r\n.content-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.content-header h2 {\r\n  font-size: 20px;\r\n  font-weight: 600;\r\n  color: #1c1e21;\r\n  margin: 0;\r\n}\r\n\r\n.location-badge {\r\n  display: flex;\r\n  align-items: center;\r\n  color: #1877f2;\r\n  font-size: 14px;\r\n  font-weight: 600;\r\n}\r\n\r\n.location-badge i {\r\n  margin-right: 6px;\r\n}\r\n\r\n/* Products Grid */\r\n.products-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));\r\n  gap: 16px;\r\n}\r\n\r\n.product-card {\r\n  background: white;\r\n  border-radius: 8px;\r\n  overflow: hidden;\r\n  cursor: pointer;\r\n  transition: transform 0.2s, box-shadow 0.2s;\r\n}\r\n\r\n.product-card:hover {\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.product-image {\r\n  width: 100%;\r\n  height: 200px;\r\n  overflow: hidden;\r\n}\r\n\r\n.product-image img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.product-info {\r\n  padding: 12px;\r\n}\r\n\r\n.product-price {\r\n  font-size: 16px;\r\n  font-weight: 600;\r\n  color: #1c1e21;\r\n  margin-bottom: 4px;\r\n}\r\n\r\n.product-name {\r\n  font-size: 14px;\r\n  color: #1c1e21;\r\n  margin-bottom: 6px;\r\n  line-height: 1.4;\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 2;\r\n  -webkit-box-orient: vertical;\r\n  overflow: hidden;\r\n}\r\n\r\n.product-location {\r\n  font-size: 13px;\r\n  color: #65676b;\r\n}\r\n\r\n/* Responsive */\r\n@media (max-width: 1024px) {\r\n  .sidebar {\r\n    transform: translateX(-100%);\r\n    transition: transform 0.3s ease;\r\n  }\r\n  \r\n  .main-content {\r\n    margin-left: 0;\r\n    padding: 16px;\r\n  }\r\n  \r\n  .products-grid {\r\n    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\r\n    gap: 12px;\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .content-header {\r\n    flex-direction: column;\r\n    align-items: flex-start;\r\n    gap: 12px;\r\n  }\r\n  \r\n  .products-grid {\r