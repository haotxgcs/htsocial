{"ast":null,"code":"import axios from \"axios\";\n// import \"../styles/ProductForm.css\"; // Import CSS file\n\nexport default {\n  data() {\n    return {\n      // Product data model\n      product: {\n        product_name: \"\",\n        description: \"\",\n        price: \"\",\n        category: \"\",\n        quantity: 1\n      },\n      priceError: \"\",\n      // Stores error message for price validation\n      message: \"\",\n      // Stores success or error messages\n      messageClass: \"\" // Stores the CSS class for message styling\n    };\n  },\n  methods: {\n    async submitForm() {\n      try {\n        const response = await axios.post(\"http://localhost:3000/products\", this.product);\n        console.log(\"Product added:\", response.data);\n\n        // Show success message\n        this.message = \"Product added successfully!\";\n        this.messageClass = \"success-message\";\n\n        // Reset price error\n        this.priceError = \"\";\n\n        // Reset form after successful submission\n        this.product = {\n          product_name: \"\",\n          description: \"\",\n          price: \"\",\n          category: \"\",\n          quantity: 1\n        };\n\n        // Hide the message after 3 seconds\n        setTimeout(() => {\n          this.message = \"\";\n        }, 3000);\n      } catch (error) {\n        console.error(\"Error adding product:\", error);\n        this.message = \"Failed to add product!\";\n        this.messageClass = \"error-message\";\n      }\n    }\n  }\n};","map":{"version":3,"names":["axios","data","product","product_name","description","price","category","quantity","priceError","message","messageClass","methods","submitForm","response","post","console","log","setTimeout","error"],"sources":["C:\\TRẦN XUÂN HÀO\\Semester 6\\COMP1842 - Web Programming 2\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\ProductForm.vue"],"sourcesContent":["<template>\r\n  <div class=\"form-container\">\r\n    <h2>Add New Product</h2>\r\n\r\n    <!-- Product Form -->\r\n    <form @submit.prevent=\"submitForm\">\r\n      <!-- Product Name Field -->\r\n      <div class=\"form-group\">\r\n        <label for=\"product_name\">Product Name:</label>\r\n        <input type=\"text\" id=\"product_name\" v-model=\"product.product_name\" required />\r\n      </div>\r\n\r\n      <!-- Product Description Field -->\r\n      <div class=\"form-group\">\r\n        <label for=\"description\">Description:</label>\r\n        <textarea id=\"description\" v-model=\"product.description\" required></textarea>\r\n      </div>\r\n\r\n      <!-- Product Price Field -->\r\n      <div class=\"form-group\">\r\n        <label for=\"price\">Price:</label>\r\n        <input type=\"number\" id=\"price\" v-model=\"product.price\" min=\"0.01\" step=\"0.01\" required />\r\n        <p v-if=\"priceError\" class=\"error-message\">{{ priceError }}</p> <!-- Display error message for price -->\r\n      </div>\r\n\r\n      <!-- Product Category Field -->\r\n      <div class=\"form-group\">\r\n        <label for=\"category\">Category:</label>\r\n        <input type=\"text\" id=\"category\" v-model=\"product.category\" required />\r\n      </div>\r\n\r\n      <!-- Product Quantity Field -->\r\n      <div class=\"form-group\">\r\n        <label for=\"quantity\">Quantity:</label>\r\n        <input type=\"number\" id=\"quantity\" v-model=\"product.quantity\" min=\"1\" required />\r\n      </div>\r\n\r\n      <!-- Submit Button -->\r\n      <button type=\"submit\" class=\"submit-btn\">Add Product</button>\r\n\r\n      <!-- Success or Error Message -->\r\n      <p v-if=\"message\" :class=\"messageClass\" class=\"message-box\">{{ message }}</p>\r\n    </form>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"axios\";\r\n// import \"../styles/ProductForm.css\"; // Import CSS file\r\n\r\nexport default {\r\n  data() {\r\n    return {\r\n      // Product data model\r\n      product: {\r\n        product_name: \"\",\r\n        description: \"\",\r\n        price: \"\",\r\n        category: \"\",\r\n        quantity: 1\r\n      },\r\n      priceError: \"\", // Stores error message for price validation\r\n      message: \"\", // Stores success or error messages\r\n      messageClass: \"\" // Stores the CSS class for message styling\r\n    };\r\n  },\r\n  methods: {\r\n    async submitForm() {\r\n      try {\r\n        const response = await axios.post(\"http://localhost:3000/products\", this.product);\r\n        console.log(\"Product added:\", response.data);\r\n\r\n        // Show success message\r\n        this.message = \"Product added successfully!\";\r\n        this.messageClass = \"success-message\";\r\n\r\n        // Reset price error\r\n        this.priceError = \"\";\r\n\r\n        // Reset form after successful submission\r\n        this.product = { product_name: \"\", description: \"\", price: \"\", category: \"\", quantity: 1 };\r\n\r\n        // Hide the message after 3 seconds\r\n        setTimeout(() => {\r\n          this.message = \"\";\r\n        }, 3000);\r\n      } catch (error) {\r\n        console.error(\"Error adding product:\", error);\r\n        this.message = \"Failed to add product!\";\r\n        this.messageClass = \"error-message\";\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style>\r\n/* Main container for the form */\r\n.form-container {\r\n  max-width: 500px; /* Set a maximum width */\r\n  margin: 20px auto; /* Center the form horizontally */\r\n  padding: 20px; /* Add padding inside the form */\r\n  background: #e6f7ff; /* White background */\r\n  border-radius: 12px; /* Rounded corners */\r\n  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15); /* Soft shadow effect */\r\n  text-align: center; /* Center align text */\r\n  border: 2px solid #d1d1d1; /* Light gray border */\r\n}\r\n\r\n/* Form title */\r\nh2 {\r\n  color: #333; /* Dark text color */\r\n  font-size: 22px; /* Set font size */\r\n  margin-bottom: 15px; /* Space below the title */\r\n  display: flex; /* Align title with icons if needed */\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 8px; /* Add spacing between elements */\r\n}\r\n\r\n/* Form group (each input field) */\r\n.form-group {\r\n  margin-bottom: 15px; /* Add space between form fields */\r\n  text-align: left; /* Align labels to the left */\r\n  width: 100%;\r\n}\r\n\r\n/* Labels for input fields */\r\nlabel {\r\n  display: block; /* Make labels appear on a new line */\r\n  font-weight: bold; /* Bold text */\r\n  margin-bottom: 5px; /* Add space below labels */\r\n  color: #555; /* Slightly dark text */\r\n}\r\n\r\n/* Input fields and text areas */\r\ninput, textarea {\r\n  width: calc(100% - 20px); /* Match button width */\r\n  padding: 10px; /* Add padding */\r\n  border-radius: 6px; /* Rounded corners */\r\n  border: 1px solid #ccc; /* Light gray border */\r\n  font-size: 14px; /* Set font size */\r\n  transition: border-color 0.2s; /* Smooth border transition */\r\n  display: block; /* Make them block elements */\r\n  margin: 0 auto; /* Center horizontally */\r\n}\r\n\r\n/* Focus effect on input fields */\r\ninput:focus, textarea:focus {\r\n  border-color: #007bff; /* Highlight input fields in blue */\r\n  outline: none; /* Remove default outline */\r\n}\r\n\r\n/* Submit button */\r\n.submit-btn {\r\n  width: 100%; /* Full width button */\r\n  padding: 12px; /* Add padding */\r\n  background: #007bff; /* Blue background */\r\n  color: white; /* White text */\r\n  font-size: 16px; /* Set font size */\r\n  border: none; /* Remove default border */\r\n  border-radius: 6px; /* Rounded corners */\r\n  cursor: pointer; /* Pointer cursor on hover */\r\n  transition: 0.2s; /* Smooth transition */\r\n  margin-top: 10px; /* Space above the button */\r\n}\r\n\r\n/* Hover effect for submit button */\r\n.submit-btn:hover {\r\n  background: #0056b3; /* Darker blue on hover */\r\n}\r\n\r\n/* Message box (for success or error messages) */\r\n.message-box {\r\n  margin-top: 10px; /* Space above messages */\r\n  padding: 10px; /* Add padding */\r\n  border-radius: 6px; /* Rounded corners */\r\n  font-weight: bold; /* Bold text */\r\n}\r\n\r\n/* Success message styling */\r\n.success-message {\r\n  background: #28a745; /* Green background */\r\n  color: white; /* White text */\r\n}\r\n\r\n/* Error message styling */\r\n.error-message {\r\n  color: red; /* Red text */\r\n  font-size: 0.9rem; /* Smaller font size */\r\n  margin-top: 5px; /* Space above the error message */\r\n}\r\n\r\n</style>"],"mappings":"AA+CA,OAAOA,KAAI,MAAO,OAAO;AACzB;;AAEA,eAAe;EACbC,IAAIA,CAAA,EAAG;IACL,OAAO;MACL;MACAC,OAAO,EAAE;QACPC,YAAY,EAAE,EAAE;QAChBC,WAAW,EAAE,EAAE;QACfC,KAAK,EAAE,EAAE;QACTC,QAAQ,EAAE,EAAE;QACZC,QAAQ,EAAE;MACZ,CAAC;MACDC,UAAU,EAAE,EAAE;MAAE;MAChBC,OAAO,EAAE,EAAE;MAAE;MACbC,YAAY,EAAE,EAAC,CAAE;IACnB,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,UAAUA,CAAA,EAAG;MACjB,IAAI;QACF,MAAMC,QAAO,GAAI,MAAMb,KAAK,CAACc,IAAI,CAAC,gCAAgC,EAAE,IAAI,CAACZ,OAAO,CAAC;QACjFa,OAAO,CAACC,GAAG,CAAC,gBAAgB,EAAEH,QAAQ,CAACZ,IAAI,CAAC;;QAE5C;QACA,IAAI,CAACQ,OAAM,GAAI,6BAA6B;QAC5C,IAAI,CAACC,YAAW,GAAI,iBAAiB;;QAErC;QACA,IAAI,CAACF,UAAS,GAAI,EAAE;;QAEpB;QACA,IAAI,CAACN,OAAM,GAAI;UAAEC,YAAY,EAAE,EAAE;UAAEC,WAAW,EAAE,EAAE;UAAEC,KAAK,EAAE,EAAE;UAAEC,QAAQ,EAAE,EAAE;UAAEC,QAAQ,EAAE;QAAE,CAAC;;QAE1F;QACAU,UAAU,CAAC,MAAM;UACf,IAAI,CAACR,OAAM,GAAI,EAAE;QACnB,CAAC,EAAE,IAAI,CAAC;MACV,EAAE,OAAOS,KAAK,EAAE;QACdH,OAAO,CAACG,KAAK,CAAC,uBAAuB,EAAEA,KAAK,CAAC;QAC7C,IAAI,CAACT,OAAM,GAAI,wBAAwB;QACvC,IAAI,CAACC,YAAW,GAAI,eAAe;MACrC;IACF;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}