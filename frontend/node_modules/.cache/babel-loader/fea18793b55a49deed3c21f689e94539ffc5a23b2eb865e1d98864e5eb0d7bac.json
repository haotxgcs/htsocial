{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nexport default {\n  name: \"MarketplacePage\",\n  data() {\n    return {\n      searchQuery: '',\n      loading: false,\n      hasMoreProducts: true,\n      products: [{\n        id: 1,\n        name: 'Oppo reno 12 5g (12-256gb)',\n        price: 5999000,\n        image: '/api/placeholder/300/300',\n        location: 'Long Xuyên',\n        timeAgo: '2 giờ trước',\n        isNew: true\n      }, {\n        id: 2,\n        name: 'S6 lite zin chạy mượt ko lỗi!!! Gl dt gaming',\n        price: 2500000,\n        image: '/api/placeholder/300/300',\n        location: 'Huyện Châu Thành, Kiền Giang, Vietnam',\n        timeAgo: '4 giờ trước',\n        isNew: false\n      }, {\n        id: 3,\n        name: 'Oppo reno 6z 5g full zin đẹp',\n        price: 2800000,\n        image: '/api/placeholder/300/300',\n        location: 'Châu Phú, An Giang, Vietnam',\n        timeAgo: '1 ngày trước',\n        isNew: false\n      }, {\n        id: 4,\n        name: 'Cần psss',\n        price: 3500000,\n        image: '/api/placeholder/300/300',\n        location: 'Cần Thơ',\n        timeAgo: '2 ngày trước',\n        isNew: false\n      }, {\n        id: 5,\n        name: 'iPhone 13 Pro Max 256GB',\n        price: 15999000,\n        image: '/api/placeholder/300/300',\n        location: 'TP.HCM',\n        timeAgo: '3 giờ trước',\n        isNew: true\n      }, {\n        id: 6,\n        name: 'Máy ảnh Canon EOS R5',\n        price: 45000000,\n        image: '/api/placeholder/300/300',\n        location: 'Hà Nội',\n        timeAgo: '5 giờ trước',\n        isNew: false\n      }]\n    };\n  },\n  computed: {\n    filteredProducts() {\n      if (!this.searchQuery) {\n        return this.products;\n      }\n      return this.products.filter(product => product.name.toLowerCase().includes(this.searchQuery.toLowerCase()) || product.location.toLowerCase().includes(this.searchQuery.toLowerCase()));\n    }\n  },\n  mounted() {\n    // Kiểm tra authentication\n    const user = JSON.parse(sessionStorage.getItem(\"user\") || localStorage.getItem(\"user\") || \"null\");\n    if (!user) {\n      return this.$router.push(\"/login\");\n    }\n  },\n  methods: {\n    handleSearch() {\n      // Implement search functionality\n      console.log('Searching for:', this.searchQuery);\n    },\n    formatPrice(price) {\n      return new Intl.NumberFormat('vi-VN', {\n        style: 'currency',\n        currency: 'VND'\n      }).format(price);\n    },\n    viewProduct(product) {\n      console.log('Viewing product:', product);\n      // Navigate to product detail page\n      // this.$router.push(`/marketplace/product/${product.id}`);\n    },\n    loadMoreProducts() {\n      this.loading = true;\n      // Simulate loading more products\n      setTimeout(() => {\n        this.loading = false;\n        // Add more products logic here\n        this.hasMoreProducts = false; // Temporarily disable for demo\n      }, 1500);\n    }\n  }\n};","map":{"version":3,"names":["name","data","searchQuery","loading","hasMoreProducts","products","id","price","image","location","timeAgo","isNew","computed","filteredProducts","filter","product","toLowerCase","includes","mounted","user","JSON","parse","sessionStorage","getItem","localStorage","$router","push","methods","handleSearch","console","log","formatPrice","Intl","NumberFormat","style","currency","format","viewProduct","loadMoreProducts","setTimeout"],"sources":["C:\\Users\\Yoga260\\Downloads\\Project\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\MarketplacePage.vue"],"sourcesContent":["<template>\r\n  <div class=\"marketplace-container\">\r\n    <!-- Header Section -->\r\n    <div class=\"marketplace-header\">\r\n      <div class=\"header-left\">\r\n        <h1 class=\"marketplace-title\">\r\n          <i class=\"fas fa-store\"></i>\r\n          Marketplace\r\n        </h1>\r\n        <div class=\"search-bar\">\r\n          <i class=\"fas fa-search search-icon\"></i>\r\n          <input \r\n            type=\"text\" \r\n            placeholder=\"Tìm kiếm sản phẩm trên Marketplace\"\r\n            v-model=\"searchQuery\"\r\n            @input=\"handleSearch\"\r\n          />\r\n        </div>\r\n      </div>\r\n      <div class=\"header-right\">\r\n        <button class=\"location-btn\">\r\n          <i class=\"fas fa-map-marker-alt\"></i>\r\n          Huyện Tân Hiệp • 65 km\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"marketplace-content\">\r\n      <!-- Sidebar -->\r\n      <div class=\"sidebar\">\r\n        <div class=\"sidebar-section\">\r\n          <div class=\"sidebar-item active\">\r\n            <i class=\"fas fa-shopping-cart\"></i>\r\n            <span>Duyệt tất cả</span>\r\n          </div>\r\n          <div class=\"sidebar-item\">\r\n            <i class=\"fas fa-bell\"></i>\r\n            <span>Thông báo</span>\r\n          </div>\r\n          <div class=\"sidebar-item\">\r\n            <i class=\"fas fa-inbox\"></i>\r\n            <span>Hộp thư</span>\r\n          </div>\r\n          <div class=\"sidebar-item\">\r\n            <i class=\"fas fa-key\"></i>\r\n            <span>Quyền truy cập Marketplace</span>\r\n          </div>\r\n          <div class=\"sidebar-item\">\r\n            <i class=\"fas fa-shopping-bag\"></i>\r\n            <span>Đang mua</span>\r\n            <i class=\"fas fa-chevron-right arrow\"></i>\r\n          </div>\r\n          <div class=\"sidebar-item\">\r\n            <i class=\"fas fa-tag\"></i>\r\n            <span>Đang bán</span>\r\n            <i class=\"fas fa-chevron-right arrow\"></i>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"create-listing-btn\">\r\n          <i class=\"fas fa-plus\"></i>\r\n          Tạo danh sách mới\r\n        </div>\r\n\r\n        <div class=\"sidebar-section\">\r\n          <h3 class=\"section-title\">Vị trí</h3>\r\n          <p class=\"location-text\">Kiên Tân, Kiền Giang, Vietnam • Trong vòng 65 km</p>\r\n        </div>\r\n\r\n        <div class=\"sidebar-section\">\r\n          <h3 class=\"section-title\">Danh mục</h3>\r\n          <div class=\"category-list\">\r\n            <div class=\"category-item\">\r\n              <i class=\"fas fa-car\"></i>\r\n              <span>Phương tiện</span>\r\n            </div>\r\n            <div class=\"category-item\">\r\n              <i class=\"fas fa-tshirt\"></i>\r\n              <span>Thời trang</span>\r\n            </div>\r\n            <div class=\"category-item\">\r\n              <i class=\"fas fa-mobile-alt\"></i>\r\n              <span>Điện tử</span>\r\n            </div>\r\n            <div class=\"category-item\">\r\n              <i class=\"fas fa-home\"></i>\r\n              <span>Gia đình & Nhà cửa</span>\r\n            </div>\r\n            <div class=\"category-item\">\r\n              <i class=\"fas fa-gamepad\"></i>\r\n              <span>Giải trí</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Main Content -->\r\n      <div class=\"main-content\">\r\n        <div class=\"content-header\">\r\n          <h2>Lựa chọn hôm nay</h2>\r\n          <div class=\"filter-buttons\">\r\n            <button class=\"filter-btn active\">Tất cả</button>\r\n            <button class=\"filter-btn\">Gần bạn</button>\r\n            <button class=\"filter-btn\">Mới nhất</button>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Product Grid -->\r\n        <div class=\"products-grid\">\r\n          <div \r\n            v-for=\"product in filteredProducts\" \r\n            :key=\"product.id\"\r\n            class=\"product-card\"\r\n            @click=\"viewProduct(product)\"\r\n          >\r\n            <div class=\"product-image\">\r\n              <img :src=\"product.image\" :alt=\"product.name\" />\r\n              <div class=\"product-badge\" v-if=\"product.isNew\">Mới</div>\r\n            </div>\r\n            <div class=\"product-info\">\r\n              <div class=\"product-price\">{{ formatPrice(product.price) }}</div>\r\n              <div class=\"product-name\">{{ product.name }}</div>\r\n              <div class=\"product-location\">{{ product.location }}</div>\r\n              <div class=\"product-time\">{{ product.timeAgo }}</div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Load More Button -->\r\n        <div class=\"load-more-container\" v-if=\"hasMoreProducts\">\r\n          <button class=\"load-more-btn\" @click=\"loadMoreProducts\">\r\n            <i class=\"fas fa-spinner fa-spin\" v-if=\"loading\"></i>\r\n            <span v-else>Xem thêm</span>\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"MarketplacePage\",\r\n  data() {\r\n    return {\r\n      searchQuery: '',\r\n      loading: false,\r\n      hasMoreProducts: true,\r\n      products: [\r\n        {\r\n          id: 1,\r\n          name: 'Oppo reno 12 5g (12-256gb)',\r\n          price: 5999000,\r\n          image: '/api/placeholder/300/300',\r\n          location: 'Long Xuyên',\r\n          timeAgo: '2 giờ trước',\r\n          isNew: true\r\n        },\r\n        {\r\n          id: 2,\r\n          name: 'S6 lite zin chạy mượt ko lỗi!!! Gl dt gaming',\r\n          price: 2500000,\r\n          image: '/api/placeholder/300/300',\r\n          location: 'Huyện Châu Thành, Kiền Giang, Vietnam',\r\n          timeAgo: '4 giờ trước',\r\n          isNew: false\r\n        },\r\n        {\r\n          id: 3,\r\n          name: 'Oppo reno 6z 5g full zin đẹp',\r\n          price: 2800000,\r\n          image: '/api/placeholder/300/300',\r\n          location: 'Châu Phú, An Giang, Vietnam',\r\n          timeAgo: '1 ngày trước',\r\n          isNew: false\r\n        },\r\n        {\r\n          id: 4,\r\n          name: 'Cần psss',\r\n          price: 3500000,\r\n          image: '/api/placeholder/300/300',\r\n          location: 'Cần Thơ',\r\n          timeAgo: '2 ngày trước',\r\n          isNew: false\r\n        },\r\n        {\r\n          id: 5,\r\n          name: 'iPhone 13 Pro Max 256GB',\r\n          price: 15999000,\r\n          image: '/api/placeholder/300/300',\r\n          location: 'TP.HCM',\r\n          timeAgo: '3 giờ trước',\r\n          isNew: true\r\n        },\r\n        {\r\n          id: 6,\r\n          name: 'Máy ảnh Canon EOS R5',\r\n          price: 45000000,\r\n          image: '/api/placeholder/300/300',\r\n          location: 'Hà Nội',\r\n          timeAgo: '5 giờ trước',\r\n          isNew: false\r\n        }\r\n      ]\r\n    }\r\n  },\r\n  computed: {\r\n    filteredProducts() {\r\n      if (!this.searchQuery) {\r\n        return this.products;\r\n      }\r\n      return this.products.filter(product =>\r\n        product.name.toLowerCase().includes(this.searchQuery.toLowerCase()) ||\r\n        product.location.toLowerCase().includes(this.searchQuery.toLowerCase())\r\n      );\r\n    }\r\n  },\r\n  mounted() {\r\n    // Kiểm tra authentication\r\n    const user = JSON.parse(sessionStorage.getItem(\"user\") || localStorage.getItem(\"user\") || \"null\");\r\n    if (!user) {\r\n      return this.$router.push(\"/login\");\r\n    }\r\n  },\r\n  methods: {\r\n    handleSearch() {\r\n      // Implement search functionality\r\n      console.log('Searching for:', this.searchQuery);\r\n    },\r\n    formatPrice(price) {\r\n      return new Intl.NumberFormat('vi-VN', {\r\n        style: 'currency',\r\n        currency: 'VND'\r\n      }).format(price);\r\n    },\r\n    viewProduct(product) {\r\n      console.log('Viewing product:', product);\r\n      // Navigate to product detail page\r\n      // this.$router.push(`/marketplace/product/${product.id}`);\r\n    },\r\n    loadMoreProducts() {\r\n      this.loading = true;\r\n      // Simulate loading more products\r\n      setTimeout(() => {\r\n        this.loading = false;\r\n        // Add more products logic here\r\n        this.hasMoreProducts = false; // Temporarily disable for demo\r\n      }, 1500);\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n* {\r\n  box-sizing: border-box;\r\n}\r\n\r\n.marketplace-container {\r\n  background-color: #f0f2f5;\r\n  min-height: 100vh;\r\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\r\n}\r\n\r\n/* Header Styles */\r\n.marketplace-header {\r\n  background: white;\r\n  padding: 16px 20px;\r\n  border-bottom: 1px solid #dadde1;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  position: sticky;\r\n  top: 0;\r\n  z-index: 100;\r\n}\r\n\r\n.header-left {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 20px;\r\n}\r\n\r\n.marketplace-title {\r\n  font-size: 24px;\r\n  font-weight: 700;\r\n  color: #1c1e21;\r\n  margin: 0;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n}\r\n\r\n.marketplace-title i {\r\n  color: #1877f2;\r\n}\r\n\r\n.search-bar {\r\n  position: relative;\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.search-bar input {\r\n  width: 320px;\r\n  padding: 8px 12px 8px 36px;\r\n  border: none;\r\n  border-radius: 50px;\r\n  background-color: #f0f2f5;\r\n  font-size: 15px;\r\n  outline: none;\r\n}\r\n\r\n.search-bar input:focus {\r\n  background-color: white;\r\n  box-shadow: 0 0 0 2px #1877f2;\r\n}\r\n\r\n.search-icon {\r\n  position: absolute;\r\n  left: 12px;\r\n  color: #65676b;\r\n  z-index: 1;\r\n}\r\n\r\n.location-btn {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  padding: 8px 12px;\r\n  background: #f0f2f5;\r\n  border: none;\r\n  border-radius: 6px;\r\n  color: #1c1e21;\r\n  cursor: pointer;\r\n  font-size: 15px;\r\n}\r\n\r\n.location-btn:hover {\r\n  background: #e4e6ea;\r\n}\r\n\r\n/* Main Content Layout */\r\n.marketplace-content {\r\n  display: flex;\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  gap: 20px;\r\n  padding: 20px;\r\n}\r\n\r\n/* Sidebar Styles */\r\n.sidebar {\r\n  width: 300px;\r\n  background: white;\r\n  border-radius: 8px;\r\n  padding: 20px;\r\n  height: fit-content;\r\n  position: sticky;\r\n  top: 100px;\r\n}\r\n\r\n.sidebar-section {\r\n  margin-bottom: 24px;\r\n}\r\n\r\n.sidebar-item {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  padding: 8px 12px;\r\n  border-radius: 8px;\r\n  cursor: pointer;\r\n  font-size: 15px;\r\n  color: #1c1e21;\r\n  position: relative;\r\n}\r\n\r\n.sidebar-item:hover {\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.sidebar-item.active {\r\n  background-color: #e7f3ff;\r\n  color: #1877f2;\r\n}\r\n\r\n.sidebar-item .arrow {\r\n  position: absolute;\r\n  right: 12px;\r\n  color: #65676b;\r\n  font-size: 12px;\r\n}\r\n\r\n.create-listing-btn {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 8px;\r\n  width: 100%;\r\n  padding: 10px;\r\n  background: #1877f2;\r\n  color: white;\r\n  border: none;\r\n  border-radius: 6px;\r\n  font-size: 15px;\r\n  font-weight: 600;\r\n  cursor: pointer;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.create-listing-btn:hover {\r\n  background: #166fe5;\r\n}\r\n\r\n.section-title {\r\n  font-size: 17px;\r\n  font-weight: 600;\r\n  color: #1c1e21;\r\n  margin: 0 0 12px 0;\r\n}\r\n\r\n.location-text {\r\n  color: #65676b;\r\n  font-size: 14px;\r\n  margin: 0;\r\n}\r\n\r\n.category-item {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  padding: 8px 12px;\r\n  border-radius: 8px;\r\n  cursor: pointer;\r\n  font-size: 15px;\r\n  color: #1c1e21;\r\n}\r\n\r\n.category-item:hover {\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.category-item i {\r\n  width: 20px;\r\n  color: #65676b;\r\n}\r\n\r\n/* Main Content Styles */\r\n.main-content {\r\n  flex: 1;\r\n}\r\n\r\n.content-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.content-header h2 {\r\n  font-size: 20px;\r\n  font-weight: 600;\r\n  color: #1c1e21;\r\n  margin: 0;\r\n}\r\n\r\n.filter-buttons {\r\n  display: flex;\r\n  gap: 8px;\r\n}\r\n\r\n.filter-btn {\r\n  padding: 8px 16px;\r\n  border: 1px solid #dadde1;\r\n  background: white;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n  font-size: 15px;\r\n  color: #1c1e21;\r\n}\r\n\r\n.filter-btn.active {\r\n  background: #1877f2;\r\n  color: white;\r\n  border-color: #1877f2;\r\n}\r\n\r\n.filter-btn:hover:not(.active) {\r\n  background: #f0f2f5;\r\n}\r\n\r\n/* Product Grid */\r\n.products-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));\r\n  gap: 16px;\r\n  margin-bottom: 32px;\r\n}\r\n\r\n.product-card {\r\n  background: white;\r\n  border-radius: 8px;\r\n  overflow: hidden;\r\n  cursor: pointer;\r\n  transition: transform 0.2s, box-shadow 0.2s;\r\n}\r\n\r\n.product-card:hover {\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.product-image {\r\n  position: relative;\r\n  width: 100%;\r\n  height: 200px;\r\n  overflow: hidden;\r\n}\r\n\r\n.product-image img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n}\r\n\r\n.product-badge {\r\n  position: absolute;\r\n  top: 8px;\r\n  left: 8px;\r\n  background: #42b883;\r\n  color: white;\r\n  padding: 4px 8px;\r\n  border-radius: 4px;\r\n  font-size: 12px;\r\n  font-weight: 600;\r\n}\r\n\r\n.product-info {\r\n  padding: 12px;\r\n}\r\n\r\n.product-price {\r\n  font-size: 18px;\r\n  font-weight: 700;\r\n  color: #1c1e21;\r\n  margin-bottom: 4px;\r\n}\r\n\r\n.product-name {\r\n  font-size: 14px;\r\n  color: #1c1e21;\r\n  margin-bottom: 8px;\r\n  line-height: 1.4;\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 2;\r\n  -webkit-box-orient: vertical;\r\n  overflow: hidden;\r\n}\r\n\r\n.product-location {\r\n  font-size: 13px;\r\n  color: #65676b;\r\n  margin-bottom: 4px;\r\n}\r\n\r\n.product-time {\r\n  font-size: 