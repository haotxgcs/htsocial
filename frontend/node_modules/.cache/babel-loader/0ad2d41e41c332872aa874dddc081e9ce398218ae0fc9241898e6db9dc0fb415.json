{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  data() {\n    return {\n      content: \"\",\n      image: null\n    };\n  },\n  methods: {\n    handleImageUpload(e) {\n      this.image = e.target.files[0];\n    },\n    async submitPost() {\n      const savedUser = JSON.parse(localStorage.getItem(\"user\"));\n      if (!savedUser) return alert(\"Bạn chưa đăng nhập\");\n      const formData = new FormData();\n      formData.append(\"content\", this.content);\n      formData.append(\"author\", savedUser.username);\n      if (this.image) {\n        formData.append(\"image\", this.image); // key phải là 'image'\n      }\n      try {\n        await this.$axios.post(\"/posts\", formData, {\n          headers: {\n            \"Content-Type\": \"multipart/form-data\"\n          }\n        });\n        alert(\"Đăng bài thành công!\");\n        this.$router.push(\"/home\");\n      } catch (err) {\n        console.error(\"Lỗi khi đăng bài:\", err);\n        alert(\"Lỗi khi đăng bài!\");\n      }\n    }\n  }\n};","map":{"version":3,"names":["data","content","image","methods","handleImageUpload","e","target","files","submitPost","savedUser","JSON","parse","localStorage","getItem","alert","formData","FormData","append","username","$axios","post","headers","$router","push","err","console","error"],"sources":["C:\\Users\\Yoga260\\Downloads\\Project\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\PostPage.vue"],"sourcesContent":["<template>\r\n  <div class=\"create-post-page\">\r\n    <h2>Tạo bài viết mới</h2>\r\n    <textarea v-model=\"content\" placeholder=\"Bạn đang nghĩ gì thế?\"></textarea>\r\n    <input type=\"file\" name=\"image\"@change=\"handleImageUpload\" accept=\"image/*,video/*\" />\r\n    <button @click=\"submitPost\">Đăng bài</button>\r\n  </div>\r\n</template>\r\n\r\n\r\n<script>\r\nexport default {\r\n  data() {\r\n    return {\r\n      content: \"\",\r\n      image: null\r\n    };\r\n  },\r\n  methods: {\r\n    handleImageUpload(e) {\r\n      this.image = e.target.files[0];\r\n    },\r\n    async submitPost() {\r\n      const savedUser = JSON.parse(localStorage.getItem(\"user\"));\r\n      if (!savedUser) return alert(\"Bạn chưa đăng nhập\");\r\n\r\n      const formData = new FormData();\r\n      formData.append(\"content\", this.content);\r\n      formData.append(\"author\", savedUser.username);\r\n      if (this.image) {\r\n        formData.append(\"image\", this.image); // key phải là 'image'\r\n      }\r\n\r\n      try {\r\n        await this.$axios.post(\"/posts\", formData, {\r\n          headers: {\r\n            \"Content-Type\": \"multipart/form-data\"\r\n          }\r\n        });\r\n        alert(\"Đăng bài thành công!\");\r\n        this.$router.push(\"/home\");\r\n      } catch (err) {\r\n        console.error(\"Lỗi khi đăng bài:\", err);\r\n        alert(\"Lỗi khi đăng bài!\");\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n\r\n<style scoped>\r\n.create-post-page {\r\n  max-width: 600px;\r\n  margin: 40px auto;\r\n  background: #fff;\r\n  padding: 20px;\r\n  border-radius: 12px;\r\n}\r\ntextarea {\r\n  width: 100%;\r\n  height: 100px;\r\n  margin-bottom: 12px;\r\n}\r\n</style>\r\n"],"mappings":";AAWA,eAAe;EACbA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,EAAE;MACXC,KAAK,EAAE;IACT,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,iBAAiBA,CAACC,CAAC,EAAE;MACnB,IAAI,CAACH,KAAI,GAAIG,CAAC,CAACC,MAAM,CAACC,KAAK,CAAC,CAAC,CAAC;IAChC,CAAC;IACD,MAAMC,UAAUA,CAAA,EAAG;MACjB,MAAMC,SAAQ,GAAIC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,CAAC,CAAC;MAC1D,IAAI,CAACJ,SAAS,EAAE,OAAOK,KAAK,CAAC,oBAAoB,CAAC;MAElD,MAAMC,QAAO,GAAI,IAAIC,QAAQ,CAAC,CAAC;MAC/BD,QAAQ,CAACE,MAAM,CAAC,SAAS,EAAE,IAAI,CAAChB,OAAO,CAAC;MACxCc,QAAQ,CAACE,MAAM,CAAC,QAAQ,EAAER,SAAS,CAACS,QAAQ,CAAC;MAC7C,IAAI,IAAI,CAAChB,KAAK,EAAE;QACda,QAAQ,CAACE,MAAM,CAAC,OAAO,EAAE,IAAI,CAACf,KAAK,CAAC,EAAE;MACxC;MAEA,IAAI;QACF,MAAM,IAAI,CAACiB,MAAM,CAACC,IAAI,CAAC,QAAQ,EAAEL,QAAQ,EAAE;UACzCM,OAAO,EAAE;YACP,cAAc,EAAE;UACl