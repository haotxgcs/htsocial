g: 20px;\r\n  border-right: 1px solid #dadde1;\r\n  position: fixed;\r\n  left: 0;\r\n  top: 0;\r\n  overflow-y: auto;\r\n}\r\n\r\n.sidebar-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.marketplace-title {\r\n  font-size: 24px;\r\n  font-weight: 700;\r\n  color: #1c1e21;\r\n  margin: 0;\r\n}\r\n\r\n.settings-icon {\r\n  font-size: 20px;\r\n  color: #65676b;\r\n  cursor: pointer;\r\n  padding: 8px;\r\n  border-radius: 50%;\r\n}\r\n\r\n.settings-icon:hover {\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.search-container {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.search-bar {\r\n  position: relative;\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.search-bar i {\r\n  position: absolute;\r\n  left: 12px;\r\n  color: #65676b;\r\n  z-index: 1;\r\n}\r\n\r\n.search-bar input {\r\n  width: 100%;\r\n  padding: 10px 16px 10px 40px;\r\n  border: none;\r\n  border-radius: 50px;\r\n  background-color: #f0f2f5;\r\n  font-size: 15px;\r\n  outline: none;\r\n}\r\n\r\n.search-bar input:focus {\r\n  background-color: white;\r\n  box-shadow: 0 0 0 2px #1877f2;\r\n}\r\n\r\n.sidebar-menu {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.menu-item {\r\n  display: flex;\r\n  align-items: center;\r\n  padding: 8px 12px;\r\n  border-radius: 8px;\r\n  cursor: pointer;\r\n  font-size: 15px;\r\n  color: #1c1e21;\r\n  margin-bottom: 4px;\r\n  position: relative;\r\n}\r\n\r\n.menu-item:hover {\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.menu-item.active {\r\n  background-color: #e7f3ff;\r\n  color: #1877f2;\r\n}\r\n\r\n.menu-item i:first-child {\r\n  width: 20px;\r\n  margin-right: 12px;\r\n}\r\n\r\n.menu-item .fa-chevron-right {\r\n  position: absolute;\r\n  right: 12px;\r\n  font-size: 12px;\r\n  color: #65676b;\r\n}\r\n\r\n.create-listing {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  padding: 10px;\r\n  background-color: #1877f2;\r\n  color: white;\r\n  border-radius: 6px;\r