\"), _createElementVNode(\"button\", null, \"📷 Ảnh\"), _createElementVNode(\"button\", null, \"🎬 Thước phim\")], -1 /* HOISTED */))]), (_openBlock(true), _createElementBlock(_Fragment, null, _renderList($data.posts, post => {\n    return _openBlock(), _createElementBlock(\"div\", {\n      class: \"post\",\n      key: post._id\n    }, [_createElementVNode(\"div\", _hoisted_6, [_createElementVNode(\"img\", {\n      src: `http://localhost:3000/${post.author.avatar || 'user.png'}`,\n      alt: \"avatar\"\n    }, null, 8 /* PROPS */, _hoisted_7), _createElementVNode(\"div\", null, [_createElementVNode(\"strong\", null, _toDisplayString(post.author.firstname) + \" \" + _toDisplayString(post.author.lastname), 1 /* TEXT */), _createElementVNode(\"div\", _hoisted_8, [_createElementVNode(\"p\", _hoisted_9, _toDisplayString($options.formatTime(post.createdAt)), 1 /* TEXT */)])]), _createCommentVNode(\" Nút menu \"), _cache[8] || (_cache[8] = _createElementVNode(\"div\", {\n      class: \"post-menu-wrapper\"\n    }, null, -1 /* HOISTED */)), _createElementVNode(\"img\", {\n      src: _imports_1,\n      class: \"menu-icon\",\n      onClick: $event => $options.toggleMenu(post._id)\n    }, null, 8 /* PROPS */, _hoisted_10), $data.openMenuId === post._id ? (_openBlock(), _createElementBlock(\"div\", _hoisted_11, [_cache[4] || (_cache[4] = _createElementVNode(\"button\", null, \"📌 Ghim bài viết\", -1 /* HOISTED */)), _cache[5] || (_cache[5] = _createElementVNode(\"button\", null, \"💾 Lưu bài viết\", -1 /* HOISTED */)), _createElementVNode(\"button\", {\n      onClick: $event => $options.editPost(post)\n    }, \"✏️ Chỉnh sửa bài viết\", 8 /* PROPS */, _hoisted_12), _cache[6] || (_cache[6] = _createElementVNode(\"button\", null, \"⚙️ Chỉnh sửa đối tượng\", -1 /* HOISTED */)), _cache[7] || (_cache[7] = _createElementVNode(\"button\", null, \"🔕 Tắt thông báo về bài viết này\", -1 /* HOISTED */))])) : _createCommentVNode(\"v-if\", true)]), _createElementVNode(\"p\", _hoisted_13, _toDisplayString(post.content), 1 /* TEXT */), _createCommentVNode(\" Media (ảnh hoặc video) \"), post.media ? (_openBlock(), _createElementBlock(\"div\", _hoisted_14, [post.mediaType === 'image' ? (_openBlock(), _createElementBlock(\"img\", {\n      key: 0,\n      src: `http://localhost:3000/${post.media}`,\n      class: \"post-image\"\n    }, null, 8 /* PROPS */, _hoisted_15)) : post.mediaType === 'video' ? (_openBlock(), _createElementBlock(\"video\", _hoisted_16, [_createElementVNode(\"source\", {\n      src: `http://localhost:3000/${post.media}`,\n      type: \"video/mp4\"\n    }, null, 8 /* PROPS */, _hoisted_17)])) : _createCommentVNode(\"v-if\", true)])) : _createCommentVNode(\"v-if\", true), _createElementVNode(\"div\", _hoisted_18, [_createElementVNode(\"button\", {\n      onClick: $event => $options.toggleLike(post)\n    }, [_createElementVNode(\"img\", {\n      src: $options.isLiked(post) ? require('../assets/like.png') : require('../assets/unlike.png'),\n      class: \"action-icon\"\n    }, null, 8 /* PROPS */, _hoisted_20), _cache[9] || (_cache[9] = _createElementVNode(\"span\", null, \"Like\", -1 /* HOISTED */))], 8 /* PROPS */, _hoisted_19), _createElementVNode(\"button\", {\n      onClick: $event => $options.commentPost(post)\n    }, [...(_cache[10] || (_cache[10] = [_createElementVNode(\"img\", {\n      src: _imports_2,\n      alt: \"Comment\",\n      class: \"action-icon\"\n    }, null, -1 /* HOISTED */), _createElementVNode(\"span\", null, \"Comment\", -1 /* HOISTED */)]))], 8 /* PROPS */, _hoisted_21), _createElementVNode(\"button\", {\n      onClick: $event => $options.sharePost(post)\n    }, [...(_cache[11] || (_cache[11] = [_createElementVNode(\"img\", {\n      src: _imports_3,\n      alt: \"Share\",\n      class: \"action-icon\"\n    }, null, -1 /* HOISTED */), _createElementVNode(\"span\", null, \"Share\", -1 /* HOISTED */)]))], 8 /* PROPS */, _hoisted_22)])]);\n  }), 128 /* KEYED_FRAGMENT */))]), _createCommentVNode(\" Sidebar phải \"), _cache[12] || (_cache[12] = _createStaticVNode(\"<aside class=\\\"sidebar-right\\\" data-v-df02a584><h3 data-v-df02a584>Người liên hệ</h3><ul data-v-df02a584><li data-v-df02a584><img src=\\\"\" + _imports_0 + \"\\\" class=\\\"menu-icon-right\\\" data-v-df02a584><span class=\\\"status online\\\" data-v-df02a584></span> Trần Xuân Hào</li><li data-v-df02a584><img src=\\\"\" + _imports_0 + \"\\\" class=\\\"menu-icon-right\\\" data-v-df02a584><span class=\\\"status online\\\" data-v-df02a584></span> Tran Hao</li><li data-v-df02a584><img src=\\\"\" + _imports_0 + \"\\\" class=\\\"menu-icon-right\\\" data-v-df02a584><span class=\\\"status offline\\\" data-v-df02a584></span> Phi Rùi</li></ul></aside>\", 1))]);\n}","map":{"version":3,"names":["_imports_0","_imports_1","_imports_2","_imports_3","class","key","controls","_createElementBlock","_hoisted_1","_createCommentVNode","_createElementVNode","_hoisted_2","_hoisted_3","src","_createTextVNode","_toDisplayString","$data","user","firstname","lastname","_createStaticVNode","_hoisted_4","_hoisted_5","type","onClick","_cache","$event","_ctx","$router","push","placeholder","_Fragment","_renderList","posts","post","_id","_hoisted_6","author","avatar","alt","_hoisted_7","_hoisted_8","_hoisted_9","$options","formatTime","createdAt","toggleMenu","_hoisted_10","openMenuId","_hoisted_11","editPost","_hoisted_12","_hoisted_13","content","media","_hoisted_14","mediaType","_hoisted_15","_hoisted_16","_hoisted_17","_hoisted_18","toggleLike","isLiked","require","_hoisted_20","_hoisted_19","commentPost","_hoisted_21","sharePost","_hoisted_22"],"sources":["C:\\Users\\Yoga260\\Downloads\\Project\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\HomePage.vue"],"sourcesContent":["<template>\r\n\r\n  <div class=\"homepage\">\r\n    <!-- Sidebar trái -->\r\n    <aside class=\"sidebar-left\">\r\n      <h2 class=\"profile-name\"><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>{{ user?.firstname }} {{ user?.lastname }}</h2>\r\n      <ul>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>Meta AI</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>Bạn bè</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>Công cụ chuyên nghiệp</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>Trang</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>Bảng feed</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>Nhóm</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>Marketplace</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>Chiến dịch gây quỹ</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>Chơi game</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>Đã lưu</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-left\"/>Đơn đặt hàng và thanh toán</li>\r\n      </ul>\r\n    </aside>\r\n\r\n    <!-- Feed chính -->\r\n    <main class=\"feed\">\r\n      <div class=\"create-post\">\r\n        <input type=\"text\" @click=\"$router.push('/posts')\" placeholder=\"Bạn đang nghĩ gì thế?\" />\r\n\r\n        <div class=\"post-options\">\r\n          <button>🎥 Video</button>\r\n          <button>📷 Ảnh</button>\r\n          <button>🎬 Thước phim</button>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"post\" v-for=\"post in posts\" :key=\"post._id\">\r\n  <div class=\"post-header\">\r\n    <img :src=\"`http://localhost:3000/${post.author.avatar || 'user.png'}`\" alt=\"avatar\" />\r\n    <div>\r\n      <strong>{{ post.author.firstname }} {{ post.author.lastname }}</strong><div class=\"post-menu-wrapper\">\r\n      <p class=\"time\">{{ formatTime(post.createdAt) }}</p>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- Nút menu -->\r\n<div class=\"post-menu-wrapper\"></div>  \r\n<img src=\"../assets/menu.png\" class=\"menu-icon\" @click=\"toggleMenu(post._id)\" />\r\n    <div v-if=\"openMenuId === post._id\" class=\"dropdown-menu\">\r\n      <button>📌 Ghim bài viết</button>\r\n      <button>💾 Lưu bài viết</button>\r\n      <button @click=\"editPost(post)\">✏️ Chỉnh sửa bài viết</button>\r\n      <button>⚙️ Chỉnh sửa đối tượng</button>\r\n      <button>🔕 Tắt thông báo về bài viết này</button>\r\n    </div>\r\n  </div>\r\n\r\n\r\n  <p class=\"post-text\">{{ post.content }}</p>\r\n\r\n  \r\n  <!-- Media (ảnh hoặc video) -->\r\n <div v-if=\"post.media\" class=\"post-media\">\r\n  <img\r\n    v-if=\"post.mediaType === 'image'\"\r\n    :src=\"`http://localhost:3000/${post.media}`\"\r\n    class=\"post-image\"\r\n  />\r\n  <video\r\n    v-else-if=\"post.mediaType === 'video'\"\r\n    controls\r\n    class=\"post-video\"\r\n  >\r\n    <source :src=\"`http://localhost:3000/${post.media}`\" type=\"video/mp4\" />\r\n    \r\n  </video>\r\n</div>\r\n\r\n  <div class=\"post-actions\">\r\n  <button @click=\"toggleLike(post)\">\r\n      <img :src=\"isLiked(post) ? require('../assets/like.png') : require('../assets/unlike.png')\" class=\"action-icon\" />\r\n      <span>Like</span>\r\n    </button>\r\n  <button @click=\"commentPost(post)\">\r\n    <img src=\"../assets/comment.png\" alt=\"Comment\" class=\"action-icon\" />\r\n    <span>Comment</span>\r\n  </button>\r\n  <button @click=\"sharePost(post)\">\r\n    <img src=\"../assets/share.png\" alt=\"Share\" class=\"action-icon\" />\r\n    <span>Share</span>\r\n  </button>\r\n</div>\r\n\r\n</div>\r\n\r\n    </main>\r\n\r\n    \r\n\r\n    <!-- Sidebar phải -->\r\n    <aside class=\"sidebar-right\">\r\n      <h3>Người liên hệ</h3>\r\n      <ul>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-right\"/><span class=\"status online\"></span> Trần Xuân Hào</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-right\"/><span class=\"status online\"></span> Tran Hao</li>\r\n        <li><img src=\"../assets/user.png\" class=\"menu-icon-right\"/><span class=\"status offline\"></span> Phi Rùi</li>\r\n      </ul>\r\n    </aside>\r\n  </div>\r\n\r\n</template>\r\n\r\n<script>\r\n\r\nexport default {\r\n  name: \"HomePage\",\r\n  data() {\r\n    return {\r\n      user: null,\r\n      posts: [],\r\n      openMenuId: null\r\n    };\r\n  },\r\n\r\n  methods: {\r\n  getImageUrl(path) {\r\n    return `http://localhost:3000/${path}`;\r\n  },\r\n  toggleMenu(postId) {\r\n    this.openMenuId = this.openMenuId === postId ? null : postId;\r\n  },\r\n  \r\n  async fetchPosts() {\r\n    try {\r\n      const res = await fetch(\"http://localhost:3000/posts\");\r\n      const data = await res.json();\r\n      this.posts = data;\r\n    } catch (err) {\r\n      console.error(\"Lỗi khi tải bài viết:\", err);\r\n    }\r\n  },\r\n  async toggleLike(post) {\r\n    const savedUser = JSON.parse(localStorage.getItem(\"user\"));\r\n    if (!savedUser) return alert(\"Vui lòng đăng nhập\");\r\n\r\n    try {\r\n      const res = await this.$axios.post(`/posts/${post._id}/like`, {\r\n        username: savedUser.username\r\n      });\r\n\r\n      post.likes = res.data.likes; // cập nhật lại mảng likes mới\r\n    } catch (err) {\r\n      console.error(\"Không thể like:\", err.response?.data || err.message);\r\n      alert(\"Không thể like bài viết\");\r\n    }\r\n  },\r\n  editPost(post) {\r\n    alert(`Chỉnh sửa bài viết: ${post.content}`);\r\n  },\r\n  async deletePost(postId) {\r\n    if (confirm(\"Bạn có chắc chắn muốn xoá bài viết?\")) {\r\n      try {\r\n        await this.$axios.delete(`/posts/${postId}`);\r\n        this.posts = this.posts.filter(p => p._id !== postId);\r\n      } catch (err) {\r\n        console.error(\"Xoá bài viết thất bại\", err);\r\n      }\r\n    }\r\n    this.openMenuId = null;\r\n  },\r\n  isLiked(post) {\r\n    const savedUser = JSON.parse(localStorage.getItem(\"user\"));\r\n    return post.likes.includes(savedUser.id); // `savedUser.id` là chuỗi\r\n  },\r\n\r\n  isImage(filePath) {\r\n    return /\\.(jpg|jpeg|png|gif)$/i.test(filePath);\r\n  },\r\n  formatTime(dateStr) {\r\n    const date = new Date(dateStr);\r\n    return date.toLocaleString();\r\n  },\r\n  \r\n  commentPost(post) {\r\n    alert(`Bạn muốn bình luận bài viết: ${post.content}`);\r\n  },\r\n  sharePost(post) {\r\n    alert(`Bạn đã chia sẻ bài viết: ${post.content}`);\r\n  }\r\n},\r\nmounted() {\r\n  const savedUser = localStorage.getItem(\"user\");\r\n  if (savedUser) {\r\n    this.user = JSON.parse(savedUser);\r\n    this.fetchPosts(); // Gọi API để lấy bài viết\r\n  } else {\r\n    this.$router.push(\"/login\");\r\n  }\r\n},\r\n\r\n};\r\n\r\n</script>\r\n\r\n\r\n<style scoped>\r\n.homepage {\r\n  display: flex;\r\n  min-height: 100vh;\r\n  background-color: #f0f2f5;\r\n  font-family: Arial, sans-serif;\r\n}\r\n\r\n.sidebar-left {\r\n  position: fixed;\r\n  top: 56px; /* chiều cao header */\r\n  left: 0;\r\n  width: 250px;\r\n  height: calc(100vh - 56px);\r\n  /* background: white; */\r\n  padding: 20px;\r\n  border-right: 1px solid #ddd;\r\n  overflow-y: auto;\r\n  z-index: 2;\r\n}\r\n\r\n.sidebar-left ul {\r\n  list-style: none;\r\n  padding: 0;\r\n}\r\n\r\n.sidebar-left li {\r\n  padding: 10px 0;\r\n  border-bottom: 1px solid #eee;\r\n  cursor: pointer;\r\n}\r\n\r\n.profile-name {\r\n  font-weight: bold;\r\n  font-size: 18px;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.feed {\r\n  width: 600px;\r\n  margin: 0 auto;\r\n  padding: 20px;\r\n  margin-left: 500px;  \r\n  /* margin-right: 230px; */\r\n}\r\n\r\n.create-post {\r\n  background: white;\r\n  padding: 15px;\r\n  border-radius: 10px;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.create-post input {\r\n  width: 95%;\r\n  padding: 12px;\r\n  font-size: 15px;\r\n  border: 1px solid #ccc;\r\n  border-radius: 8px;\r\n}\r\n\r\n.post-options {\r\n  display: flex;\r\n  justify-content: space-around;\r\n  margin-top: 10px;\r\n}\r\n\r\n.post-options button {\r\n  background: #eee;\r\n  border: none;\r\n  padding: 8px 12px;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n}\r\n\r\n.post {\r\n  background: white;\r\n  padding: 15px;\r\n  border-radius: 10px;\r\n  margin-bottom: 20px;\r\n   margin-top: 10px;\r\n}\r\n\r\n.post-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  /* align-items: center; */\r\n  position: relative;\r\n}\r\n\r\n.post-header img {\r\n  width: 40px;\r\n  height: 40px;\r\n  border-radius: 999px;\r\n  margin-right: 10px;\r\n}\r\n\r\n.post-header .time {\r\n  font-size: 12px;\r\n  color: gray;\r\n  margin-top: 2px;\r\n}\r\n\r\n.post-text {\r\n  margin: 10px 0;\r\n  font-size: 14px;\r\n}\r\n\r\n.post-image {\r\n  width: 100%;\r\n  border-radius: 10px;\r\n  margin-top: 10px;\r\n}\r\n\r\n.sidebar-right {\r\n  position: fixed;\r\n  top: 56px;\r\n  right: 0;\r\n  width: 220px;\r\n  height: calc(100vh - 56px);\r\n  /* background: white; */\r\n  padding: 20px;\r\n  border-left: 1px solid #ddd;\r\n  overflow-y: auto;\r\n  z-index: 2;\r\n}\r\n\r\n.sidebar-right ul {\r\n  list-style: none;\r\n  padding: 0;\r\n}\r\n\r\n.sidebar-right li {\r\n  display: flex;\r\n  align-items: center;\r\n  margin: 10px 0;\r\n}\r\n\r\n.status {\r\n  width: 10px;\r\n  height: 10px;\r\n  border-radius: 999px;\r\n  margin-right: 8px;\r\n}\r\n\r\n.online {\r\n  background-color: green;\r\n}\r\n\r\n.offline {\r\n  background-color: gray; \r\n}\r\n\r\n/* Header Style */\r\n.header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  background: white;\r\n  height: 56px;\r\n  padding: 0 16px;\r\n  border-bottom: 1px solid #ccc;\r\n  position: sticky;\r\n  top: 0;\r\n  z-index: 10;\r\n}\r\n\r\n\r\n.left {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.logo {\r\n  height: 36px;\r\n  margin-right: 12px;\r\n}\r\n\r\n.search {\r\n  background: #f0f2f5;\r\n  border: none;\r\n  padding: 8px 12px;\r\n  border-radius: 999px;\r\n  font-size: 14px;\r\n  width: 220px;\r\n}\r\n\r\n\r\n.center i {\r\n  font-size: 20px;\r\n  color: #606770;\r\n  cursor: pointer;\r\n  position: relative;\r\n}\r\n\r\