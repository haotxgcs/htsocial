n\r\n        <div class=\"search-bar\">\r\n          <i class=\"fas fa-search\"></i>\r\n           <h1>Marketplace</h1>\r\n          <input type=\"text\" placeholder=\"Search Marketplace\" v-model=\"searchQuery\">\r\n        </div>\r\n\r\n        <div class=\"menu-list\">\r\n          <div class=\"menu-item active\">\r\n            <div class=\"menu-icon blue-bg\">\r\n              <i class=\"fas fa-shopping-cart\"></i>\r\n            </div>\r\n            <span>Browse all</span>\r\n          </div>\r\n          \r\n          <div class=\"menu-item\">\r\n            <i class=\"fas fa-bell\"></i>\r\n            <span>Notifications</span>\r\n          </div>\r\n          \r\n          <div class=\"menu-item\">\r\n            <i class=\"fas fa-inbox\"></i>\r\n            <span>Inbox</span>\r\n          </div>\r\n          \r\n          <div class=\"menu-item\">\r\n            <i class=\"fas fa-shield-alt\"></i>\r\n            <span>Marketplace access</span>\r\n          </div>\r\n          \r\n          <div class=\"menu-item\">\r\n            <i class=\"fas fa-shopping-bag\"></i>\r\n            <span>Buying</span>\r\n            <i class=\"fas fa-chevron-right arrow\"></i>\r\n          </div>\r\n          \r\n          <div class=\"menu-item\">\r\n            <i class=\"fas fa-tag\"></i>\r\n            <span>Selling</span>\r\n            <i class=\"fas fa-chevron-right arrow\"></i>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"create-btn\">\r\n          <i class=\"fas fa-plus\"></i>\r\n          Create new listing\r\n        </div>\r\n\r\n        <div class=\"sidebar-section\">\r\n          <h3>Location</h3>\r\n          <p>Kiên Tân, Kiền Giang, Vietnam • Within 65 km</p>\r\n        </div>\r\n\r\n        <div class=\"sidebar-section\">\r\n          <h3>Categories</h3>\r\n          <div class=\"menu-item\">\r\n            <i class=\"fas fa-car\"></i>\r\n            <span>Vehicles</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Main Content -->\r\n      <div class=\"main-content\">\r\n        <div class=\"content-header\">\r\n          <h2>Today's picks</h2>\r\n          <div class=\"location-tag\">\r\n            <i class=\"fas fa-map-marker-alt\"></i>\r\n            Huyện Tân Hiệp • 65 km\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Products Grid - Facebook Style -->\r\n        <div class=\"products-grid\">\r\n          <div v-for=\"product in products\" :key=\"product.id\" class=\"product-item\">\r\n            <div class=\"product-image\">\r\n              <img :src=\"product.image\" :alt=\"product.name\">\r\n            </div>\r\n            <div class=\"product-details\">\r\n              <div class=\"price\">{{ product.price }}</div>\r\n              <div class=\"title\">{{ product.title }}</div>\r\n              <div class=\"location\">{{ product.location }}</div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"MarketplacePage\",\r\n  data() {\r\n    return {\r\n      searchQuery: '',\r\n      products: [\r\n        {\r\n          id: 1,\r\n          price: 'đ1,050,000',\r\n          title: 'Dự xài, bán điện thoại Samsung A51',\r\n          location: 'Cần Thơ',\r\n          image: 'https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=400&h=300&fit=crop'\r\n        },\r\n        {\r\n          id: 2,\r\n          price: 'đ1,300,000',\r\n          title: 'Samsung a51',\r\n          location: 'Hòa Long, An Giang, Vietnam',\r\n          image: 'https://images.unsplash.com/photo-1544244015-0df4b3ffc6b0?w=400&h=300&fit=crop'\r\n        },\r\n        {\r\n          id: 3,\r\n          price: 'đ3,000,000',\r\n          title: 'Rog phone 5 nói đã 8/128gb',\r\n          location: 'Cần Thơ',\r\n          image: 'https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=400&h=300&fit=crop'\r\n        },\r\n        {\r\n          id: 4,\r\n          price: 'đ7,500,000',\r\n          title: 'Ipad mini 6',\r\n          location: 'Cần Thơ',\r\n          image: 'https://images.unsplash.com/photo-1544244015-0df4b3ffc6b0?w=400&h=300&fit=crop'\r\n        },\r\n        {\r\n          id: 5,\r\n          price: 'đ2,500,000',\r\n          title: 'Máy ảnh cũ chất lượng tốt',\r\n          location: 'TP.HCM',\r\n          image: 'https://images.unsplash.com/photo-1606983340126-99ab4feaa64a?w=400&h=300&fit=crop'\r\n        },\r\n        {\r\n          id: 6,\r\n          price: 'đ15,000,000',\r\n          title: 'Xe máy Honda Winner 150',\r\n          location: 'Hà Nội',  \r\n          image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&h=300&fit=crop'\r\n        },\r\n        {\r\n          id: 7,\r\n          price: 'đ8,500,000',\r\n          title: 'Laptop Dell Gaming',\r\n          location: 'Đà Nẵng',\r\n          image: 'https://images.unsplash.com/photo-1593640408182-31c70c8268f5?w=400&h=300&fit=crop'\r\n        },\r\n        {\r\n          id: 8,\r\n          price: 'đ1,200,000',\r\n          title: 'Điện thoại iPhone cũ',\r\n          location: 'Cần Thơ',\r\n          image: 'https://images.unsplash.com/photo-1592750475338-74b7b21085ab?w=400&h=300&fit=crop'\r\n        }\r\n      ]\r\n    }\r\n  },\r\n  mounted() {\r\n    const user = JSON.parse(sessionStorage.getItem(\"user\") || localStorage.getItem(\"user\") || \"null\");\r\n    if (!user) {\r\n      return this.$router.push(\"/login\");\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n* {\r\n  margin: 0;\r\n  padding: 0;\r\n  box-sizing: border-box;\r\n}\r\n\r\n.marketplace-container {\r\n  background-color: #f0f2f5;\r\n  min-height: 100vh;\r\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\r\n}\r\n\r\n.marketplace-layout {\r\n  display: flex;\r\n}\r\n\r\n/* Sidebar */\r\n.sidebar {\r\n  width: 320px;\r\n  background: white;\r\n  height: 100vh;\r\n  padding: 16px;\r\n  position: fixed;\r\n  left: 0;\r\n  top: 0;\r\n  overflow-y: auto;\r\n  border-right: 1px solid #dadde1;\r\n}\r\n\r\n.sidebar-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 16px;\r\n}\r\n\r\n.sidebar-header h1 {\r\n  font-size: 20px;\r\n  font-weight: 700;\r\n  color: #1c1e21;\r\n}\r\n\r\n.sidebar-header i {\r\n  font-size: 20px;\r\n  color: #65676b;\r\n  cursor: pointer;\r\n  padding: 8px;\r\n  border-radius: 50%;\r\n}\r\n\r\n.sidebar-header i:hover {\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.search-bar {\r\n  position: relative;\r\n  margin-bottom: 16px;\r\n}\r\n\r\n.search-bar i {\r\n  position: absolute;\r\n  left: 12px;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  color: #65676b;\r\n}\r\n\r\n.search-bar input {\r\n  width: 100%;\r\n  padding: 8px 16px 8px 36px;\r\n  border: none;\r\n  border-radius: 50px;\r\n  background-color: #f0f2f5;\r\n  font-size: 15px;\r\n  outline: none;\r\n}\r\n\r\n.menu-list {\r\n  margin-bottom: 16px;\r\n}\r\n\r\n.menu-item {\r\n  display: flex;\r\n  align-items: center;\r\n  padding: 8px;\r\n  border-radius: 8px;\r\n  cursor: pointer;\r\n  margin-bottom: 2px;\r\n  position: relative;\r\n}\r\n\r\n.menu-item:hover {\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.menu-item.active {\r\n  background-color: #e7f3ff;\r\n}\r\n\r\n.menu-icon {\r\n  width: 36px;\r\n  height: 36px;\r\n  border-radius: 50%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  margin-right: 12px;\r\n}\r\n\r\n.blue-bg {\r\n  background-color: #1877f2;\r\n  color: white;\r\n}\r\n\r\n.menu-item > i:first-child {\r\n  width: 20px;\r\n  margin-right: 12px;\r\n  color: #65676b;\r\n}\r\n\r\n.menu-item span {\r\n  font-size: 15px;\r\n  color: #1c1e21;\r\n  font-weight: 500;\r\n}\r\n\r\n.arrow {\r\n  position: absolute;\r\n  right: 8px;\r\n  font-size: 12px;\r\n  color: #65676b;\r\n}\r\n\r\n.create-btn {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  padding: 8px 16px;\r\n  background-color: #1877f2;\r\n  color: white;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n  font-size: 15px;\r\n  font-weight: 600;\r\n  margin-bottom: 24px;\r\n}\r\n\r\n.create-btn:hover {\r\n  background-color: #166fe5;\r\n}\r\n\r\n.create-btn i {\r\n  margin-right: 8px;\r\n}\r\n\r\n.sidebar-section {\r\n  margin-bottom: 16px;\r\n}\r\n\r\n.sidebar-section h3 {\r\n  font-size: 17px;\r\n  font-weight: 600;\r\n  color: #1c1e21;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.sidebar-section p {\r\n  font-size: 14px;\r\n  color: #65676b;\r\n  line-height: 1.4;\r\n}\r\n\r\n/* Main Content */\r\n.main-content {\r\n  flex: 1;\r\n  margin-left: 320px;\r\n  padding: 20px;\r\n  max-width: calc(100vw - 340px);\r\n}\r\n\r\n.content-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 24px;\r\n  padding: 0 4px;\r\n}\r\n\r\n.content-header h2 {\r\n  font-size: 24px;\r\n  font-weight: 700;\r\n  color: #1c1e21;\r\n}\r\n\r\n.location-tag {\r\n  display: flex;\r\n  align-items: center;\r\n  color: #1877f2;\r\n  font-size: 15px;\r\n  font-weight: 600;\r\n  background-color: #e7f3ff;\r\n  padding: 8px 12px;\r\n  border-radius: 20px;\r\n}\r\n\r\n.location-tag i {\r\n  margin-right: 6px;\r\n}\r\n\r\n/* Products Grid - Tối ưu cho 4 cột và hình ảnh lớn */\r\n.products-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(4, 1fr);\r\n  gap: 24px;\r\n  width: 100%;\r\n  margin-top: 16px;\r\n  align-items: start;\r\n}\r\n\r\n.product-item {\r\n  background: white;\r\n  border-radius: 12px;\r\n  overflow: hidden;\r\n  cursor: pointer;\r\n  transition: all 0.3s ease;\r\n  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);\r\n  border: 1px solid #e4e6ea;\r\n  display: flex;\r\n  flex-direction: column;\r\n  height: 100%;\r\n}\r\n\r\n.product-item:hover {\r\n  transform: translateY(-6px);\r\n  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);\r\n  border-color: #1877f2;\r\n}\r\n\r\n.product-image {\r\n  width: 100%;\r\n  height: 300px; /* Hình ảnh to hơn */\r\n  overflow: hidden;\r\n  position: relative;\r\n  background-color: #f8f9fa;\r\n}\r\n\r\n.product-image img {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  transition: transform 0.4s ease;\r\n}\r\n\r\n.product-item:hover .product-image img {\r\n  transform: scale(1.08);\r\n}\r\n\r\n.product-details {\r\n  padding: 18px;\r\n  min-height: 150px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: space-between;\r\n  flex: 1;\r\n}\r\n\r\n.price {\r\n  font-size: 20px;\r\n  font-weight: 700;\r\n  color: #1877f2;\r\n  margin-bottom: 10px;\r\n  line-height: 1.2;\r\n}\r\n\r\n.title {\r\n  font-size: 16px;\r\n  color: #1c1e21;\r\n  line-height: 1.4;\r\n  margin-bottom: 10px;\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 2;\r\n  -webkit-box-orient: vertical;\r\n  overflow: hidden;\r\n  font-weight: 500;\r\n  flex: 1;\r\n}\r\n\r\n.location {\r\n  font-size: 14px;\r\n  color: #65676b;\r\n  display: flex;\r\n  align-items: center;\r\n  margin-top: auto;\r\n  padding-top: 8px;\r\n  border-top: 1px solid #f0f2f5;\r\n}\r\n\r\n.location::before {\r\n  content: \"📍\";\r\n  margin-right: 6px;\r\n  font-size: 13px;\r\n}\r\n\r\n/* Responsive Design */\r\n@media (max-width: 1400px) {\r\n  .products-grid {\r\n    grid-template-columns: repeat(4, 1fr);\r\n    gap: 20px;\r\n  }\r\n  \r\n  .product-image {\r\n    height: 280px;\r\n  }\r\n  \r\n  .product-details {\r\n    padding: 16px;\r\n    min-height: 140px;\r\n  }\r\n  \r\n  .price {\r\n    font-size: 18px;\r\n  }\r\n  \r\n  .title {\r\n    font-size: 15px;\r\n  }\r\n}\r\n\r\n@media (max-width: 1200px) {\r\n  .products-grid {\r\n    grid-template-columns: repeat(4, 1fr);\r\n    gap: 18px;\r\n  }\r\n  \r\n  .product-image {\r\n    height: 260px;\r\n  }\r\n  \r\n  .product-details {\r\n    padding: 15px;\r\n    min-height: 130px;\r\n  }\r\n}\r\n\r\n@media (max-width: 1024px) {\r\n  .products-grid {\r\n    grid-template-columns: repeat(3, 1fr);\