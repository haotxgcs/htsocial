         <i class=\"fas fa-inbox\"></i>\r\n            </div>\r\n            <span>Inbox</span>\r\n          </div>\r\n          \r\n          <div class=\"menu-item\">\r\n            <div class=\"menu-icon\">\r\n              <i class=\"fas fa-shield-alt\"></i>\r\n            </div>\r\n            <span>Marketplace access</span>\r\n          </div>\r\n          \r\n          <div class=\"menu-item\">\r\n            <div class=\"menu-icon\">\r\n              <i class=\"fas fa-shopping-bag\"></i>\r\n            </div>\r\n            <span>Buying</span>\r\n            <i class=\"fas fa-chevron-right arrow\"></i>\r\n          </div>\r\n          \r\n          <div class=\"menu-item\">\r\n            <div class=\"menu-icon\">\r\n              <i class=\"fas fa-tag\"></i>\r\n            </div>\r\n            <span>Selling</span>\r\n            <i class=\"fas fa-chevron-right arrow\"></i>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"create-btn\">\r\n          <i class=\"fas fa-plus\"></i>\r\n          Create new listing\r\n        </div>\r\n\r\n        <div class=\"sidebar-section\">\r\n          <h3>Location</h3>\r\n          <p class=\"location-text\">Kiên Tân, Kiên Giang, Vietnam • Within 65 km</p>\r\n        </div>\r\n\r\n        <div class=\"sidebar-section\">\r\n          <h3>Categories</h3>\r\n          <div class=\"menu-item\">\r\n            <div class=\"menu-icon\">\r\n              <i class=\"fas fa-car\"></i>\r\n            </div>\r\n            <span>Vehicles</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Main Content -->\r\n      <div class=\"main-content\">\r\n        <div class=\"content-header\">\r\n          <h2>Today's picks</h2>\r\n          <div class=\"location-tag\">\r\n            <i class=\"fas fa-map-marker-alt\"></i>\r\n            Huyện Tân Hiệp • 65 km\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Products Grid -->\r\n        <div class=\"products-grid\">\r\n          <div v-for=