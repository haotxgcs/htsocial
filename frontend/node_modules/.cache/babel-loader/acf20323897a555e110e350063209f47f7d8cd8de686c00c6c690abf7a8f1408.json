s.image = e.target.files[0];\r\n    },\r\n    async submitPost() {\r\n      const formData = new FormData();\r\n      const savedUser = JSON.parse(localStorage.getItem('user'));\r\n\r\n      if (!savedUser?.username) {\r\n        this.error = \"Không thể xác định người dùng.\";\r\n        return;\r\n      }\r\n\r\n      formData.append('content', this.content);\r\n      formData.append('author', savedUser.username);\r\n      if (this.image) formData.append('image', this.image);\r\n\r\n      try {\r\n        await this.$axios.post('/posts', formData);\r\n        this.$router.push('/home');\r\n      } catch (err) {\r\n        console.error(\"Lỗi khi đăng bài:\", err);\r\n        this.error =\r\n          err.response?.data?.msg || \"Không thể đăng bài. Vui lòng thử lại.\";\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.create-post-page {\r\n  max-width: 600px;\r\n  margin: 40px auto;\r\n  background: #fff;\r\n  padding: 20px;\r\n  border-radius: 12px;\r\n}\r\ntextarea {\r\n  width: 100%;\r\n  height: 100px;\r\n  margin-bottom: 12px;\r\n}\r\n.error {\r\n  color: red;\r\n  margin-top: 10px;\r\n}\r\n</style>\r\n"],"mappings":";AAWA,eAAe;EACbA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,EAAE;MACXC,KAAK,EAAE,IAAI;MACXC,KAAK,EAAE;IACT,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,iBAAiBA,CAACC,CAAC,EAAE;MACnB,IAAI,CAACJ,KAAI,GAAII,CAAC,CAACC,MAAM,CAACC,KAAK,CAAC,CAAC,CAAC;IAChC,CAAC;IACD,MAAMC,UAAUA,CAAA,EAAG;MACjB,MAAMC,QAAO,GAAI,IAAIC,QAAQ,CAAC,CAAC;MAC/B,MAAMC,SAAQ,GAAIC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,CAAC,CAAC;MAE1D,IAAI,CAACJ,SAAS,EAAEK,QAAQ,EAAE;QACxB,IAAI,CAACd,KAAI,GAAI,gCAAgC;QAC7C;MACF;MAEAO,QAAQ,CAACQ,MAAM,CAAC,SAAS,EAAE,IAAI,CAACjB,OAAO,CAAC;MACxCS,QAAQ,CAACQ,MAAM,CAAC,QAAQ,EAAEN,SAAS,CAACK,QAAQ,CAAC;MAC7C,IAAI,IAAI,CAACf,KAAK,EAAEQ,QAAQ,CAACQ,MAAM,CAAC,OAAO,EAAE,IAAI,CAAChB,KAAK,CAAC;MAEpD,IAAI;QACF,MAAM,IAAI,CAACiB,MAAM,CAACC,IAAI,CAAC,QAAQ,EAAEV,QAAQ,CAAC;QAC1C,IAAI,CAACW,OAAO,CAACC,IAAI,CAAC,OAAO,CAAC;MAC5B,EAAE,OAAOC,GAAG,EAAE