{"ast":null,"code":"export default {\n  name: \"HeaderBar\"\n};","map":{"version":3,"names":["name"],"sources":["C:\\Users\\Yoga260\\Downloads\\COMP1842 - Web Programming 2\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\Header.vue"],"sourcesContent":["<template>\r\n  <header class=\"header\">\r\n    <!-- Left: Logo + Search -->\r\n    <div class=\"left\">\r\n      <img src=\"/facebook-logo.png\" alt=\"Logo\" class=\"logo\" />\r\n      <input type=\"text\" placeholder=\"Tìm kiếm trên Facebook\" class=\"search\" />\r\n    </div>\r\n\r\n    <!-- Center: Navigation Icons -->\r\n    <div class=\"center\">\r\n      <i class=\"fas fa-home active\"></i>\r\n      <i class=\"fas fa-user-friends\"></i>\r\n      <i class=\"fas fa-store\"></i>\r\n      <i class=\"fas fa-users\"></i>\r\n      <i class=\"fas fa-gamepad\"></i>\r\n    </div>\r\n\r\n    <!-- Right: Actions -->\r\n    <div class=\"right\">\r\n      <div class=\"icon-circle\"><i class=\"fas fa-th\"></i></div>\r\n      <div class=\"icon-circle\"><i class=\"fab fa-facebook-messenger\"></i></div>\r\n      <div class=\"icon-circle notification\">\r\n        <i class=\"fas fa-bell\"></i>\r\n        <span class=\"badge\">1</span>\r\n      </div>\r\n      <div class=\"icon-circle\"><i class=\"fas fa-user-circle\"></i></div>\r\n    </div>\r\n  </header>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"HeaderBar\"\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  background: white;\r\n  height: 56px;\r\n  padding: 0 16px;\r\n  border-bottom: 1px solid #ccc;\r\n  position: sticky;\r\n  top: 0;\r\n  z-index: 10;\r\n}\r\n\r\n.left {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.logo {\r\n  height: 36px;\r\n  margin-right: 12px;\r\n}\r\n\r\n.search {\r\n  background: #f0f2f5;\r\n  border: none;\r\n  padding: 8px 12px;\r\n  border-radius: 999px;\r\n  font-size: 14px;\r\n  width: 220px;\r\n}\r\n\r\n.center {\r\n  display: flex;\r\n  gap: 24px;\r\n}\r\n\r\n.center i {\r\n  font-size: 20px;\r\n  color: #606770;\r\n  cursor: pointer;\r\n  position: relative;\r\n}\r\n\r\n.center i.active {\r\n  color: #1877f2;\r\n  border-bottom: 3px solid #1877f2;\r\n  padding-bottom: 3px;\r\n}\r\n\r\n.right {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n}\r\n\r\n.icon-circle {\r\n  background: #e4e6eb;\r\n  width: 36px;\r\n  height: 36px;\r\n  border-radius: 50%;\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  cursor: pointer;\r\n  position: relative;\r\n}\r\n\r\n.badge {\r\n  position: absolute;\r\n  top: -2px;\r\n  right: -2px;\r\n  background: red;\r\n  color: white;\r\n  font-size: 10px;\r\n  border-radius: 999px;\r\n  padding: 2px 5px;\r\n}\r\n</style>\r\n"],"mappings":"AA+BA,eAAe;EACbA,IAAI,EAAE;AACR,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}