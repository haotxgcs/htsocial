{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'RegisterPage',\n  data() {\n    return {\n      firstname: '',\n      lastname: '',\n      username: '',\n      email: '',\n      password: '',\n      error: ''\n    };\n  },\n  methods: {\n    async handleRegister() {\n      try {\n        const res = await fetch('http://localhost:3000/auth/register', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json'\n          },\n          body: JSON.stringify({\n            firstname: this.firstName,\n            lastname: this.lastName,\n            username: this.username,\n            email: this.email,\n            password: this.password\n          })\n        });\n        const data = await res.json();\n        if (!res.ok) throw new Error(data.msg || 'Registration failed');\n        alert('Registration successful!');\n        this.$router.push('/login');\n      } catch (err) {\n        this.error = err.message;\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","firstname","lastname","username","email","password","error","methods","handleRegister","res","fetch","method","headers","body","JSON","stringify","firstName","lastName","json","ok","Error","msg","alert","$router","push","err","message"],"sources":["C:\\Users\\Yoga260\\Downloads\\COMP1842 - Web Programming 2\\COMP1842_TRAN_XUAN_HAO_COS1106\\coursework\\frontend\\src\\components\\RegisterPage.vue"],"sourcesContent":["<template>\r\n  <div class=\"form-container\">\r\n    <h2>Sign Up</h2>\r\n    <form @submit.prevent=\"handleRegister\">\r\n      <input v-model=\"firstname\" placeholder=\"First Name\" required />\r\n      <input v-model=\"lastname\" placeholder=\"Last Name\" required />\r\n      <input v-model=\"username\" placeholder=\"Username\" required />\r\n      <input v-model=\"email\" type=\"email\" placeholder=\"Email\" required />\r\n      <input v-model=\"password\" type=\"password\" placeholder=\"Password\" required />\r\n      <button type=\"submit\">Register</button>\r\n    </form>\r\n    <p v-if=\"error\">{{ error }}</p>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'RegisterPage',\r\n  data() {\r\n    return {\r\n      firstname: '',\r\n      lastname: '',\r\n      username: '',\r\n      email: '',\r\n      password: '',\r\n      error: ''\r\n    }\r\n  },\r\n  methods: {\r\n    async handleRegister() {\r\n      try {\r\n        const res = await fetch('http://localhost:3000/auth/register', {\r\n          method: 'POST',\r\n          headers: { 'Content-Type': 'application/json' },\r\n          body: JSON.stringify({\r\n            firstname: this.firstName,\r\n            lastname: this.lastName,\r\n            username: this.username,\r\n            email: this.email,\r\n            password: this.password\r\n          })\r\n        });\r\n        const data = await res.json();\r\n        if (!res.ok) throw new Error(data.msg || 'Registration failed');\r\n        \r\n        alert('Registration successful!');\r\n        this.$router.push('/login');\r\n\r\n      } catch (err) {\r\n        this.error = err.message;\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.form-container {\r\n  max-width: 400px;\r\n  margin: 100px auto;\r\n  background: white;\r\n  padding: 30px;\r\n  border-radius: 8px;\r\n}\r\ninput {\r\n  display: block;\r\n  width: 100%;\r\n  padding: 10px;\r\n  margin: 12px 0;\r\n}\r\nbutton {\r\n  padding: 10px;\r\n  width: 100%;\r\n}\r\n</style>\r\n"],"mappings":";AAgBA,eAAe;EACbA,IAAI,EAAE,cAAc;EACpBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAE,EAAE;MACbC,QAAQ,EAAE,EAAE;MACZC,QAAQ,EAAE,EAAE;MACZC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,KAAK,EAAE;IACT;EACF,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,cAAcA,CAAA,EAAG;MACrB,IAAI;QACF,MAAMC,GAAE,GAAI,MAAMC,KAAK,CAAC,qCAAqC,EAAE;UAC7DC,MAAM,EAAE,MAAM;UACdC,OAAO,EAAE;YAAE,cAAc,EAAE;UAAmB,CAAC;UAC/CC,IAAI,EAAEC,IAAI,CAACC,SAAS,CAAC;YACnBd,SAAS,EAAE,IAAI,CAACe,SAAS